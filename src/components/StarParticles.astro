<canvas id="starfield"></canvas>

<script>
(function() {
  const canvas = document.getElementById('starfield');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  let w, h, particles = [];
  const COUNT = 60;
  const MAX_SPEED = 0.08;

  function resize() {
    w = canvas.width = window.innerWidth;
    h = canvas.height = window.innerHeight;
  }

  function createParticle() {
    return {
      x: Math.random() * w,
      y: Math.random() * h,
      vx: (Math.random() - 0.5) * MAX_SPEED * 0.3,
      vy: -Math.random() * MAX_SPEED * 0.5 - 0.01,
      r: Math.random() * 1.6 + 0.3,
      a: Math.random() * 0.4 + 0.3,
      phase: Math.random() * Math.PI * 2,
    };
  }

  function init() {
    resize();
    particles = Array.from({ length: COUNT }, createParticle);
  }

  let running = true;

  function draw(time) {
    if (!running) return;
    ctx.clearRect(0, 0, w, h);

    for (let i = 0; i < particles.length; i++) {
      const p = particles[i];

      // Twinkle
      const twinkle = Math.sin(time * 0.001 + p.phase) * 0.15 + 0.85;

      // Move
      p.x += p.vx;
      p.y += p.vy;

      // Wrap
      if (p.y < -10) { p.y = h + 10; p.x = Math.random() * w; }
      if (p.x < -10) p.x = w + 10;
      if (p.x > w + 10) p.x = -10;

      // Draw
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(180, 200, 230, ${p.a * twinkle})`;
      ctx.fill();
    }

    requestAnimationFrame(draw);
  }

  // ── Pause when hidden ──
  document.addEventListener('visibilitychange', () => {
    if (document.hidden) {
      running = false;
    } else {
      running = true;
      requestAnimationFrame(draw);
    }
  });

  init();
  requestAnimationFrame(draw);

  let resizeTimer;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      resize();
      particles.forEach(p => {
        p.x = Math.min(p.x, w);
        p.y = Math.min(p.y, h);
      });
    }, 200);
  });
})();
</script>

<style>
  #starfield {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    will-change: transform;
  }
</style>
