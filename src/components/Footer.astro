---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner container-wide">
    <p>© {year} Guorui Tong</p>
    <div class="footer-links">
      <a href="https://github.com/tgrlhl-linux" target="_blank" rel="noopener">GitHub</a>
      <a href="mailto:1767242545@qq.com">Email</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding: 2rem 0;
    margin-top: 2rem;
  }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .footer p { font-size: 0.8rem; color: var(--text-muted); margin: 0; }
  .footer-links { display: flex; gap: 1.5rem; }
  .footer-links a { font-size: 0.8rem; color: var(--text-muted); text-decoration: none; }
  .footer-links a:hover { color: var(--accent); }
</style>
