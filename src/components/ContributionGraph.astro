---
/**
 * GitHub 风格贡献热力图
 *
 * Props:
 *   data    — { [dateStr]: count }  日期 → 活跃度
 *   labels  — { [dateStr]: string } 日期 → 悬停提示文字（可选）
 */

const CELL = 12;
const GAP = 3;
const STEP = CELL + GAP;
const PAD = { top: 24, right: 16, bottom: 8, left: 40 };

const DAY_LABELS = ['', '一', '', '三', '', '五', ''];
const MONTHS = ['1月','2月','3月','4月','5月','6月','7月','8月','9月','10月','11月','12月'];

const today = new Date();
const end = new Date(today.getFullYear(), today.getMonth(), today.getDate());
// 找到上一个周六作为结束列
const endDow = end.getDay(); // 0=Sun
const endSat = new Date(end);
endSat.setDate(endSat.getDate() - (endDow + 1) % 7);

// 52 周前
const start = new Date(endSat);
start.setDate(start.getDate() - 51 * 7);

function pad(n) { return n < 10 ? '0' + n : '' + n; }
function dateStr(d) {
  return d.getFullYear() + '-' + pad(d.getMonth() + 1) + '-' + pad(d.getDate());
}

// 生成网格数据
interface CellInfo { date: string; count: number; label: string; level: number; }
const grid: CellInfo[][] = [];

function getLevel(n) {
  if (n === 0) return 0;
  if (n === 1) return 1;
  if (n <= 3) return 2;
  if (n <= 6) return 3;
  return 4;
}

const dataMap = Astro.props.data || {};
const labelMap = Astro.props.labels || {};

const cursor = new Date(start);
for (let w = 0; w < 53; w++) {
  const week: CellInfo[] = [];
  for (let d = 0; d < 7; d++) {
    const ds = dateStr(cursor);
    const count = dataMap[ds] || 0;
    week.push({
      date: ds,
      count,
      label: labelMap[ds] || (count > 0 ? count + ' 条记录' : '无活动'),
      level: getLevel(count),
    });
    cursor.setDate(cursor.getDate() + 1);
  }
  grid.push(week);
}

// SVG 尺寸
const W = PAD.left + grid.length * STEP + PAD.right;
const H = PAD.top + 7 * STEP + PAD.bottom;

// 月份标签
const monthLabels: { x: number; label: string }[] = [];
grid.forEach((week, wi) => {
  const d = new Date(start);
  d.setDate(d.getDate() + wi * 7);
  const m = d.getMonth();
  if (wi === 0 || d.getDate() <= 7) {
    monthLabels.push({ x: PAD.left + wi * STEP, label: MONTHS[m] });
  }
});
---

<div class="cg-wrap">
  <svg width={W} height={H} viewBox={`0 0 ${W} ${H}`} class="cg-svg" role="img" aria-label="贡献热力图">
    <!-- 月份 -->
    {monthLabels.map(m => (
      <text x={m.x} y={12} class="cg-month">{m.label}</text>
    ))}
    <!-- 星期 -->
    {DAY_LABELS.map((l, i) => l ? (
      <text x={8} y={PAD.top + i * STEP + 10} class="cg-dow">{l}</text>
    ) : null)}
    <!-- 格子 -->
    {grid.map((week, wi) => week.map((cell, di) => (
      <rect
        x={PAD.left + wi * STEP}
        y={PAD.top + di * STEP}
        width={CELL} height={CELL}
        rx="2" ry="2"
        class={`cg-cell lv-${cell.level}`}
      >
        <title>{cell.date} — {cell.label}</title>
      </rect>
    )))}
  </svg>

  <!-- 图例 -->
  <div class="cg-legend">
    <span class="cg-legend-label">少</span>
    {[0,1,2,3,4].map(l => (
      <span class={`cg-swatch lv-${l}`}></span>
    ))}
    <span class="cg-legend-label">多</span>
  </div>
</div>

<style>
  .cg-wrap {
    display: flex; flex-direction: column; gap: 0.3rem;
    padding: 1rem 0; overflow-x: auto;
  }
  .cg-svg { display: block; }
  .cg-month { fill: var(--text-muted); font-size: 10px; }
  .cg-dow { fill: var(--text-muted); font-size: 9px; text-anchor: end; }

  .cg-cell { outline: none; transition: opacity 0.1s; }
  .cg-cell:hover { opacity: 0.8; stroke: var(--text); stroke-width: 1; }

  .cg-cell.lv-0 { fill: rgba(255,255,255,0.04); }
  .cg-cell.lv-1 { fill: #0e4429; }
  .cg-cell.lv-2 { fill: #006d32; }
  .cg-cell.lv-3 { fill: #26a641; }
  .cg-cell.lv-4 { fill: #39d353; }

  [data-theme="light"] .cg-cell.lv-0 { fill: #ebedf0; }
  [data-theme="light"] .cg-cell.lv-1 { fill: #9be9a8; }
  [data-theme="light"] .cg-cell.lv-2 { fill: #40c463; }
  [data-theme="light"] .cg-cell.lv-3 { fill: #30a14e; }
  [data-theme="light"] .cg-cell.lv-4 { fill: #216e39; }

  .cg-legend {
    display: flex; align-items: center; gap: 3px;
    justify-content: flex-end; padding-right: 4px;
  }
  .cg-legend-label { font-size: 10px; color: var(--text-muted); }
  .cg-swatch {
    display: inline-block; width: 10px; height: 10px;
    border-radius: 2px;
  }
  .cg-swatch.lv-0 { background: rgba(255,255,255,0.04); }
  .cg-swatch.lv-1 { background: #0e4429; }
  .cg-swatch.lv-2 { background: #006d32; }
  .cg-swatch.lv-3 { background: #26a641; }
  .cg-swatch.lv-4 { background: #39d353; }

  [data-theme="light"] .cg-swatch.lv-0 { background: #ebedf0; }
  [data-theme="light"] .cg-swatch.lv-1 { background: #9be9a8; }
  [data-theme="light"] .cg-swatch.lv-2 { background: #40c463; }
  [data-theme="light"] .cg-swatch.lv-3 { background: #30a14e; }
  [data-theme="light"] .cg-swatch.lv-4 { background: #216e39; }
</style>
