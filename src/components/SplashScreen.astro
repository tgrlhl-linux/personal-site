<!-- ── 入口 Splash ──
GSAP 文字动画 + Three.js 粒子氛围
-->

<!-- GSAP CDN -->
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>

<div id="splash-overlay" class="splash-overlay">
  <canvas id="splash-canvas"></canvas>

  <div class="splash-content" id="splash-content">
    <div class="text-block" id="text-block">
      <div class="signature" id="signature">—— 行路 · 自题</div>
      <div class="line line-1" id="line1"></div>
      <div class="line line-2" id="line2"></div>
    </div>

    <div class="hero-section" id="hero-section">
      <h1 class="hero-name">童国睿</h1>
      <p class="hero-sub">软件工程 · 大三 · 贵州大学</p>
      <p class="hero-desc">从底层系统到前端界面，用代码解决问题的过程都记录在这里。</p>
      <div class="hero-links">
        <a href="/projects" class="btn">浏览项目</a>
        <a href="/about" class="btn btn-outline">关于我</a>
      </div>
    </div>
  </div>

  <button class="skip-btn" id="skip-btn">跳过 ›</button>
</div>

<style>
  .splash-overlay {
    position: fixed; inset: 0; z-index: 9999;
    background: #060a14;
    display: flex; align-items: center; justify-content: center;
    transition: opacity 0.8s ease, transform 1s ease;
    transform-origin: center;
  }
  .splash-overlay.fade-out {
    opacity: 0; transform: scale(1.05); pointer-events: none;
  }
  .splash-overlay.hidden { display: none; }

  #splash-canvas {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    pointer-events: none;
  }

  .splash-content {
    position: relative; z-index: 1;
    text-align: center;
    perspective: 1000px;
    width: 100%; max-width: 800px;
    padding: 2rem;
  }

  .text-block {
    margin-bottom: 2rem;
  }

  .line {
    margin: 0.5rem 0;
  }
  .line .char {
    display: inline-block;
    font-size: 3.2rem;
    font-weight: 300;
    letter-spacing: 10px;
    color: #e6edf3;
    text-shadow: 0 0 30px rgba(88,166,255,0.2);
    opacity: 0;
    will-change: transform, opacity;
  }
  .line-1 .char {
    background: linear-gradient(135deg, #58a6ff 0%, #bc8cff 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .line-2 .char {
    background: linear-gradient(135deg, #bc8cff 0%, #e6edf3 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .signature {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.3);
    letter-spacing: 4px;
    margin-bottom: 1.5rem;
    opacity: 0;
  }

  .hero-section {
    opacity: 0;
    transform: translateY(20px);
  }
  .hero-name {
    font-size: 2.2rem;
    font-weight: 700;
    color: #e6edf3;
    margin-bottom: 0.3rem;
  }
  .hero-sub {
    font-size: 0.9rem; color: rgba(255,255,255,0.4);
    margin-bottom: 0.6rem;
  }
  .hero-desc {
    font-size: 0.9rem; color: rgba(255,255,255,0.35);
    margin-bottom: 1.2rem; max-width: 500px; margin-left: auto; margin-right: auto;
  }
  .hero-links { display: flex; gap: 0.8rem; justify-content: center; }
  .hero-links .btn {
    display: inline-block; padding: 0.5rem 1.4rem;
    border-radius: 8px; font-size: 0.88rem;
    background: #1f6feb; color: #fff; text-decoration: none;
    transition: background 0.2s;
  }
  .hero-links .btn:hover { background: #58a6ff; }
  .hero-links .btn-outline {
    background: transparent; border: 1px solid rgba(255,255,255,0.15); color: rgba(255,255,255,0.6);
  }
  .hero-links .btn-outline:hover { border-color: #58a6ff; color: #58a6ff; }

  .skip-btn {
    position: fixed; bottom: 2rem; right: 2rem; z-index: 10000;
    background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.4); padding: 0.5rem 1.2rem;
    border-radius: 20px; font-size: 0.8rem; cursor: pointer;
    transition: all 0.2s; backdrop-filter: blur(4px);
    font-family: -apple-system, "Noto Sans SC", sans-serif;
    opacity: 0;
  }
  .skip-btn:hover { background: rgba(255,255,255,0.12); color: rgba(255,255,255,0.7); }

  @media (max-width: 640px) {
    .line .char { font-size: 1.8rem; letter-spacing: 6px; }
    .hero-name { font-size: 1.6rem; }
    .skip-btn { bottom: 1rem; right: 1rem; font-size: 0.7rem; padding: 0.4rem 1rem; }
  }
  @media (max-width: 380px) {
    .line .char { font-size: 1.4rem; letter-spacing: 4px; }
  }
</style>

<script is:inline type="importmap">
{
  "imports": {
    "three": "https://cdn.jsdelivr.net/npm/three@0.170.0/build/three.module.js"
  }
}
</script>

<script is:inline type="module">
// ═══════════════════════════════════════════════════════════
// GSAP 文字动画 + Three.js 粒子背景
// ═══════════════════════════════════════════════════════════

import * as THREE from 'three';

const overlay = document.getElementById('splash-overlay');
const canvas = document.getElementById('splash-canvas');
const skipBtn = document.getElementById('skip-btn');
const line1 = document.getElementById('line1');
const line2 = document.getElementById('line2');
const signature = document.getElementById('signature');
const heroSection = document.getElementById('hero-section');

// ── Skip check ──
if (sessionStorage.getItem('splash_played') ||
    window.matchMedia?.('(prefers-reduced-motion: reduce)').matches) {
  overlay.classList.add('hidden');
} else {
  document.body.classList.add('splash-active');
  init();
}

function init() {

// ═══ Three.js Particles ═══
const scene = new THREE.Scene();
const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 200);
camera.position.z = 50;

const renderer = new THREE.WebGLRenderer({ canvas, alpha: true });
renderer.setSize(window.innerWidth, window.innerHeight);
renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

// Create particle texture
function makeDot() {
  const c = document.createElement('canvas');
  c.width = 32; c.height = 32;
  const ctx = c.getContext('2d');
  const g = ctx.createRadialGradient(16, 16, 0, 16, 16, 16);
  g.addColorStop(0, 'rgba(255,255,255,1)');
  g.addColorStop(0.2, 'rgba(200,220,255,0.8)');
  g.addColorStop(1, 'rgba(255,255,255,0)');
  ctx.fillStyle = g; ctx.fillRect(0, 0, 32, 32);
  return new THREE.CanvasTexture(c);
}

const PARTICLE_COUNT = 500;
const pPos = new Float32Array(PARTICLE_COUNT * 3);
const pSizes = new Float32Array(PARTICLE_COUNT);
const pSpeeds = [];

for (let i = 0; i < PARTICLE_COUNT; i++) {
  pPos[i*3] = (Math.random() - 0.5) * 100;
  pPos[i*3+1] = (Math.random() - 0.5) * 60;
  pPos[i*3+2] = (Math.random() - 0.5) * 40 - 20;
  pSizes[i] = 0.3 + Math.random() * 1.5;
  pSpeeds.push({
    x: (Math.random() - 0.5) * 0.02,
    y: (Math.random() - 0.5) * 0.02,
    phase: Math.random() * Math.PI * 2,
  });
}

const geo = new THREE.BufferGeometry();
geo.setAttribute('position', new THREE.BufferAttribute(pPos, 3));
geo.setAttribute('size', new THREE.BufferAttribute(pSizes, 1));

const mat = new THREE.PointsMaterial({
  map: makeDot(),
  size: 0.4,
  transparent: true,
  opacity: 0.6,
  blending: THREE.AdditiveBlending,
  depthWrite: false,
  color: 0x88bbff,
  sizeAttenuation: true,
});
const particles = new THREE.Points(geo, mat);
scene.add(particles);

function animateParticles(time) {
  const pos = particles.geometry.attributes.position;
  for (let i = 0; i < PARTICLE_COUNT; i++) {
    pos.array[i*3] += pSpeeds[i].x;
    pos.array[i*3+1] += pSpeeds[i].y;
    // Wrap
    if (pos.array[i*3] > 50) pos.array[i*3] = -50;
    if (pos.array[i*3] < -50) pos.array[i*3] = 50;
    if (pos.array[i*3+1] > 30) pos.array[i*3+1] = -30;
    if (pos.array[i*3+1] < -30) pos.array[i*3+1] = 30;
  }
  pos.needsUpdate = true;
  particles.rotation.y += 0.0005;
  particles.rotation.x = Math.sin(time * 0.0001) * 0.05;
  renderer.render(scene, camera);
  requestAnimationFrame(animateParticles);
}
animateParticles(0);

// ── Generate characters ──
const text1 = '倦随尘絮争朝暮';
const text2 = '独逐星鸿赴大荒';

function makeChars(container, text) {
  [...text].forEach(ch => {
    const span = document.createElement('span');
    span.className = 'char';
    span.textContent = ch;
    container.appendChild(span);
  });
}
makeChars(line1, text1);
makeChars(line2, text2);

// ── GSAP Timeline ──
const tl = gsap.timeline({
  onComplete: () => {
    // Show skip button after text animation
    gsap.to(skipBtn, { opacity: 1, duration: 0.5 });
  }
});

// Phase 1: Line 1 — each character flips in
tl.fromTo('.line-1 .char',
  { opacity: 0, y: -50, rotationX: -75, filter: 'blur(6px)' },
  { opacity: 1, y: 0, rotationX: 0, filter: 'blur(0px)',
    duration: 0.7, stagger: 0.07, ease: 'back.out(1.5)' }
);

// Phase 2: Line 2 — characters flip in
tl.fromTo('.line-2 .char',
  { opacity: 0, y: 50, rotationX: 75, filter: 'blur(6px)' },
  { opacity: 1, y: 0, rotationX: 0, filter: 'blur(0px)',
    duration: 0.7, stagger: 0.07, ease: 'back.out(1.5)' },
  '+=0.15'
);

// Phase 3: Signature fades in
tl.fromTo(signature,
  { opacity: 0, y: 8 },
  { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out' }
);

// Phase 4: Hero section slides up
tl.fromTo(heroSection,
  { opacity: 0, y: 25 },
  { opacity: 1, y: 0, duration: 0.8, ease: 'power2.out' },
  '+=0.2'
);

// Phase 5: Pause, then transition
tl.to({}, { duration: 1.5 });

// Phase 6: Fade out splash
tl.to(overlay, {
  opacity: 0, scale: 1.05, duration: 0.8, ease: 'power2.inOut',
  onComplete: endSplash
});

// ── End splash ──
function endSplash() {
  sessionStorage.setItem('splash_played', '1');
  document.body.classList.remove('splash-active');
  overlay.classList.add('hidden');
  renderer.dispose();
}

// ── Skip ──
let skipped = false;
function skip() {
  if (skipped) return;
  skipped = true;
  tl.progress(1);
  endSplash();
}
skipBtn.addEventListener('click', skip);
overlay.addEventListener('click', (e) => {
  if (e.target === overlay || e.target.tagName === 'CANVAS') skip();
});
window.addEventListener('keydown', (e) => {
  if (['Escape', ' ', 'Enter'].includes(e.key)) skip();
});

// ── Resize ──
window.addEventListener('resize', () => {
  camera.aspect = window.innerWidth / window.innerHeight;
  camera.updateProjectionMatrix();
  renderer.setSize(window.innerWidth, window.innerHeight);
});

} // init()
</script>
