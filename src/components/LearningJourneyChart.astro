---
import { journeyData, phaseConfig } from '../data/learning-journey.js';

const PAD = { top: 30, right: 24, bottom: 44, left: 48 };
const W = 720;
const H = 360;
const IW = W - PAD.left - PAD.right;
const IH = H - PAD.top - PAD.bottom;

const minYear = Math.min(...journeyData.map(d => d.year));
const maxYear = Math.max(...journeyData.map(d => d.year));
const yearRange = maxYear - minYear;

function xPos(d) { return PAD.left + ((d.year - minYear) / yearRange) * IW; }
function yPos(d) { return PAD.top + IH - (d.value / 100) * IH; }

function smoothPath(points) {
  if (points.length < 2) return '';
  let d = `M ${xPos(points[0])} ${yPos(points[0])}`;
  for (let i = 1; i < points.length; i++) {
    const prev = points[i - 1];
    const curr = points[i];
    const cpx1 = xPos(prev) + (xPos(curr) - xPos(prev)) * 0.4;
    const cpy1 = yPos(prev);
    const cpx2 = xPos(prev) + (xPos(curr) - xPos(prev)) * 0.6;
    const cpy2 = yPos(curr);
    d += ` C ${cpx1} ${cpy1}, ${cpx2} ${cpy2}, ${xPos(curr)} ${yPos(curr)}`;
  }
  return d;
}

const lastPoint = journeyData[journeyData.length - 1];
const linePath = smoothPath(journeyData);
const areaPath = linePath + ` L ${xPos(lastPoint)} ${PAD.top + IH} L ${xPos(journeyData[0])} ${PAD.top + IH} Z`;

const yTicks = [0, 25, 50, 75, 100];

const phases = ['middle-school', 'high-school', 'university'];
const phaseRanges = phases.map(ph => {
  const pts = journeyData.filter(d => d.phase === ph);
  if (!pts.length) return null;
  return {
    key: ph,
    ...phaseConfig[ph],
    x: xPos(pts[0]),
    w: pts.length > 1 ? xPos(pts[pts.length - 1]) - xPos(pts[0]) : IW / 12,
  };
}).filter(Boolean);

const xLabels = journeyData.filter(d => !d.year.toString().includes('.'));
const jsonData = JSON.stringify(journeyData);
const jsonPhases = JSON.stringify(phaseConfig);
---

<div class="jc-wrap">
  <svg viewBox={`0 0 ${W} ${H}`} class="jc-svg" role="img" aria-label="学习成长轨迹">
    <defs>
      <linearGradient id="areaGrad" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#3fb950" stop-opacity="0.3" />
        <stop offset="100%" stop-color="#3fb950" stop-opacity="0.02" />
      </linearGradient>
      <linearGradient id="lineGrad" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color="#58a6ff" />
        <stop offset="50%" stop-color="#d29922" />
        <stop offset="100%" stop-color="#3fb950" />
      </linearGradient>
    </defs>

    <!-- 阶段背景 -->
    {phaseRanges.map(ph => (
      <rect x={ph.x} y={PAD.top} width={ph.w} height={IH}
        fill={ph.area} rx="4" />
    ))}

    <!-- 网格线 -->
    {yTicks.map(v => (
      <g>
        <line x1={PAD.left} y1={yPos({value: v})}
          x2={PAD.left + IW} y2={yPos({value: v})}
          stroke="var(--border)" stroke-width="0.5" />
        <text x={PAD.left - 8} y={yPos({value: v}) + 4}
          text-anchor="end" class="jc-tick">{v}</text>
      </g>
    ))}

    <text x={12} y={PAD.top + IH / 2 + 4}
      text-anchor="middle" class="jc-axis-label"
      transform={`rotate(-90, 12, ${PAD.top + IH / 2})`}>成长指数</text>

    <!-- 面积 + 折线 -->
    <path d={areaPath} fill="url(#areaGrad)" class="jc-area" />
    <path d={linePath} fill="none" stroke="url(#lineGrad)" stroke-width="3"
      stroke-linecap="round" stroke-linejoin="round" class="jc-line" />

    <!-- 数据点（可点击） -->
    {journeyData.map((d, i) => (
      <g class="jc-dot-group" data-idx={i}>
        <!-- 点击热区（大圆） -->
        <circle cx={xPos(d)} cy={yPos(d)} r="16" fill="transparent"
          class="jc-hit" data-idx={i} />
        <!-- 可见圆点 -->
        <circle cx={xPos(d)} cy={yPos(d)} r="6" fill="var(--bg-card)"
          stroke={d.phase === 'university' ? '#3fb950' : '#58a6ff'}
          stroke-width="2.5" class="jc-dot" data-idx={i} />
      </g>
    ))}

    <!-- X 轴标签 -->
    {xLabels.map(d => (
      <text x={xPos(d)} y={H - 8} text-anchor="middle" class="jc-xlabel">{d.label}</text>
    ))}
  </svg>

  <!-- 图例 -->
  <div class="jc-legend">
    {phaseRanges.map(ph => (
      <span class="jc-legend-item">
        <span class="jc-legend-dot" style={`background:${ph.color}`}></span>
        {ph.label}
      </span>
    ))}
    <span class="jc-legend-hint">💡 点击圆点查看详情</span>
  </div>
</div>

<!-- 详情弹窗 -->
<div id="jc-modal" class="jc-modal" style="display:none">
  <div class="jc-modal-overlay" id="jc-modal-overlay"></div>
  <div class="jc-modal-box">
    <button class="jc-modal-close" id="jc-modal-close">✕</button>
    <div class="jc-modal-stage" id="jc-modal-stage"></div>
    <h2 class="jc-modal-title" id="jc-modal-title"></h2>
    <div class="jc-modal-value">成长指数 <span id="jc-modal-val"></span></div>
    <ul class="jc-modal-list" id="jc-modal-list"></ul>
  </div>
</div>

<script id="jc-data" type="application/json">{jsonData}</script>
<script id="jc-phases" type="application/json">{jsonPhases}</script>

<script>
(function() {
  // 从 JSON script 标签读取数据
  var data = JSON.parse(document.getElementById('jc-data').textContent);
  var phases = JSON.parse(document.getElementById('jc-phases').textContent);

  // 入场动画
  var line = document.querySelector('.jc-line');
  if (line) {
    var len = line.getTotalLength();
    line.style.strokeDasharray = len;
    line.style.strokeDashoffset = len;
    requestAnimationFrame(function() {
      line.style.transition = 'stroke-dashoffset 1.8s ease-out';
      line.style.strokeDashoffset = '0';
    });
  }

  var modal = document.getElementById('jc-modal');
  var overlay = document.getElementById('jc-modal-overlay');
  var closeBtn = document.getElementById('jc-modal-close');
  var stageEl = document.getElementById('jc-modal-stage');
  var titleEl = document.getElementById('jc-modal-title');
  var valEl = document.getElementById('jc-modal-val');
  var listEl = document.getElementById('jc-modal-list');

  function openModal(idx) {
    var d = data[idx];
    if (!d) return;
    var cfg = phases[d.phase] || { label: d.phase, color: '#58a6ff' };
    stageEl.textContent = cfg.label;
    stageEl.style.color = cfg.color;
    stageEl.style.borderColor = cfg.color;
    stageEl.style.background = cfg.color + '18';
    titleEl.textContent = d.label;
    valEl.textContent = d.value;
    listEl.innerHTML = '';
    if (d.events && d.events.length) {
      d.events.forEach(function(ev) {
        var li = document.createElement('li');
        li.textContent = ev;
        listEl.appendChild(li);
      });
    } else {
      var li = document.createElement('li');
      li.textContent = '暂无详细记录';
      li.style.color = 'var(--text-muted)';
      listEl.appendChild(li);
    }
    modal.style.display = 'flex';
    requestAnimationFrame(function() {
      modal.classList.add('jc-modal-open');
    });
  }

  function closeModal() {
    modal.classList.remove('jc-modal-open');
    setTimeout(function() { modal.style.display = 'none'; }, 200);
  }

  // 点击数据点
  document.querySelectorAll('.jc-hit').forEach(function(el) {
    el.addEventListener('click', function(e) {
      openModal(parseInt(this.getAttribute('data-idx')));
    });
  });

  // 点击关闭 / 遮罩
  closeBtn.addEventListener('click', closeModal);
  overlay.addEventListener('click', closeModal);

  // Escape 键关闭
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && modal.style.display !== 'none') closeModal();
  });
})();
</script>

<style>
  .jc-wrap { padding: 1rem 0; overflow-x: auto; }
  .jc-svg { display: block; width: 100%; max-width: 720px; margin: 0 auto; }
  .jc-tick { fill: var(--text-muted); font-size: 10px; font-family: var(--font-mono); }
  .jc-axis-label { fill: var(--text-muted); font-size: 10px; }
  .jc-xlabel { fill: var(--text-muted); font-size: 11px; font-weight: 500; }
  .jc-area, .jc-line { pointer-events: none; }
  .jc-dot { transition: r 0.15s; cursor: pointer; }
  .jc-hit { cursor: pointer; }
  .jc-dot-group:hover .jc-dot { r: 7.5; }

  .jc-legend {
    display: flex; gap: 1rem; justify-content: center;
    align-items: center; margin-top: 0.5rem; flex-wrap: wrap;
  }
  .jc-legend-item { display: flex; align-items: center; gap: 0.3rem; font-size: 0.75rem; color: var(--text-secondary); }
  .jc-legend-dot { width: 8px; height: 8px; border-radius: 50%; }
  .jc-legend-hint { font-size: 0.7rem; color: var(--text-muted); margin-left: 0.5rem; }

  /* ── Modal ── */
  .jc-modal {
    display: none;
    position: fixed; inset: 0; z-index: 1000;
    justify-content: center; align-items: center;
  }
  .jc-modal-overlay {
    position: absolute; inset: 0;
    background: rgba(0,0,0,0.5);
    backdrop-filter: blur(4px);
  }
  .jc-modal-box {
    position: relative;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem 1.8rem;
    max-width: 420px;
    width: 90%;
    box-shadow: 0 24px 80px rgba(0,0,0,0.5);
    transform: scale(0.92) translateY(12px);
    opacity: 0;
    transition: transform 0.25s ease-out, opacity 0.2s ease-out;
  }
  .jc-modal-open .jc-modal-box {
    transform: scale(1) translateY(0);
    opacity: 1;
  }
  .jc-modal-close {
    position: absolute; top: 0.8rem; right: 1rem;
    background: none; border: none;
    font-size: 1.1rem; color: var(--text-muted);
    cursor: pointer; padding: 0.2rem; line-height: 1;
    border-radius: 4px; transition: color 0.1s;
  }
  .jc-modal-close:hover { color: var(--text); }
  .jc-modal-stage {
    display: inline-block;
    font-size: 0.7rem; padding: 0.15em 0.6em;
    border-radius: 6px; border: 1px solid;
    margin-bottom: 0.6rem;
  }
  .jc-modal-title {
    font-size: 1.3rem; font-weight: 700;
    margin: 0 0 0.2rem; line-height: 1.3;
    color: var(--text);
  }
  .jc-modal-value {
    font-size: 0.8rem; color: var(--text-muted);
    margin-bottom: 1rem; font-family: var(--font-mono);
  }
  .jc-modal-value span { color: var(--c-os); font-weight: 600; }
  .jc-modal-list {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-direction: column; gap: 0.35rem;
  }
  .jc-modal-list li {
    position: relative;
    padding-left: 1rem;
    font-size: 0.88rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }
  .jc-modal-list li::before {
    content: '·';
    position: absolute; left: 0.15rem;
    color: var(--c-os);
    font-weight: 700;
  }
</style>
