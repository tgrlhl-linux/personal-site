---
// 浮动聊天气泡组件
// 自动挂载到页面右下角，点击后展开聊天面板
---

<div id="chat-widget" data-astro-cid-chat>
  <!-- 气泡按钮 + 标签 -->
  <div class="cb-wrapper">
    <span class="cb-hint" id="chat-hint">网站智能助手</span>
    <div class="cb-ring"></div>
    <button id="chat-toggle" class="chat-bubble" aria-label="打开聊天" title="网站智能助手">
      <svg class="cb-icon cb-default" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      </svg>
      <svg class="cb-icon cb-close" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <!-- 聊天面板 -->
  <div id="chat-panel" class="chat-panel">
    <div class="cp-header">
      <span class="cp-title">💬 和我聊聊</span>
      <button id="chat-close" class="cp-close" aria-label="关闭聊天">✕</button>
    </div>
    <div id="chat-messages" class="cp-messages">
      <div class="msg msg-ai">
        <div class="msg-avatar">🤖</div>
        <div class="msg-content">你好呀 👋 有什么想聊的？</div>
      </div>
    </div>
    <div class="cp-input-wrap">
      <textarea id="chat-input" class="cp-input" rows="1" placeholder="说点什么…" maxlength="2000"></textarea>
      <button id="chat-send" class="cp-send" aria-label="发送">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
      </button>
    </div>
  </div>
</div>

<script>
document.addEventListener('astro:page-load', initChatWidget);
document.addEventListener('DOMContentLoaded', initChatWidget);
function initChatWidget() {
  // ---- DOM refs ----
  const toggle = document.getElementById('chat-toggle');
  const panel = document.getElementById('chat-panel');
  const closeBtn = document.getElementById('chat-close');
  const messagesEl = document.getElementById('chat-messages');
  const input = document.getElementById('chat-input');
  const sendBtn = document.getElementById('chat-send');

  if (!toggle || !panel || toggle.dataset.chatInited) return;
  toggle.dataset.chatInited = 'true';

  let isOpen = false;
  let isWaiting = false;

  // ---- helpers ----
  function scrollToBottom() {
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function addMessage(role, text) {
    const div = document.createElement('div');
    div.className = 'msg msg-' + role;
    const avatar = role === 'user'
      ? '<div class="msg-avatar">🙋</div>'
      : '<div class="msg-avatar">🤖</div>';
    div.innerHTML = avatar + '<div class="msg-content"></div>';
    messagesEl.appendChild(div);
    const contentEl = div.querySelector('.msg-content');
    contentEl.textContent = text;
    scrollToBottom();
    return { div, contentEl };
  }

  function showError(msg) {
    const div = document.createElement('div');
    div.className = 'msg msg-ai msg-error';
    div.innerHTML = '<div class="msg-avatar">⚠️</div><div class="msg-content" style="color:var(--c-db);font-size:0.82rem">' + msg + '</div>';
    messagesEl.appendChild(div);
    scrollToBottom();
  }

  // ---- toggle ----
  const hint = document.getElementById('chat-hint');

  function openChat() {
    isOpen = true;
    panel.classList.add('open');
    toggle.classList.add('active');
    if (hint) hint.style.display = 'none';
    input.focus();
  }

  function closeChat() {
    isOpen = false;
    panel.classList.remove('open');
    toggle.classList.remove('active');
    if (hint) hint.style.display = '';
  }

  toggle.addEventListener('click', () => isOpen ? closeChat() : openChat());
  closeBtn.addEventListener('click', closeChat);

  // ---- send ----
  async function sendMessage() {
    const text = input.value.trim();
    if (!text || isWaiting) return;

    input.value = '';
    input.style.height = 'auto';

    // 用户消息
    addMessage('user', text);

    // 占位 AI 消息
    const { contentEl } = addMessage('ai', '');
    isWaiting = true;
    sendBtn.disabled = true;
    sendBtn.style.opacity = '0.4';

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ messages: [{ role: 'user', content: text }] }),
      });

      if (!res.ok) {
        const err = await res.json();
        contentEl.textContent = '出错了: ' + (err.error || '请求失败');
        return;
      }

      // SSE 流式读取
      const reader = res.body.getReader();
      const decoder = new TextDecoder();
      let buffer = '';
      let fullText = '';

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;

        buffer += decoder.decode(value, { stream: true });
        const lines = buffer.split('\n');
        buffer = lines.pop() || '';

        for (const line of lines) {
          if (!line.startsWith('data: ')) continue;
          const data = line.slice(6).trim();
          if (data === '[DONE]') continue;
          try {
            const parsed = JSON.parse(data);
            const delta = parsed.choices?.[0]?.delta?.content;
            if (delta) {
              fullText += delta;
              contentEl.textContent = fullText;
              scrollToBottom();
            }
          } catch (e) {
            // 跳过解析失败的行
          }
        }
      }
    } catch (e) {
      contentEl.textContent = '网络错误，请重试';
      showError('网络连接失败，请检查网络后重试');
    } finally {
      isWaiting = false;
      sendBtn.disabled = false;
      sendBtn.style.opacity = '1';
    }
  }

  sendBtn.addEventListener('click', sendMessage);
  input.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      sendMessage();
    }
  });

  // 自动调整 textarea 高度
  input.addEventListener('input', () => {
    input.style.height = 'auto';
    input.style.height = Math.min(input.scrollHeight, 120) + 'px';
  });
}
</script>

<style>
  /* ── 气泡容器（左上角） ── */
  .cb-wrapper {
    position: fixed;
    top: 4.5rem;
    left: 1.2rem;
    z-index: 900;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  /* ── 脉冲光环 ── */
  .cb-ring {
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    border: 2px solid rgba(88,166,255,0.35);
    animation: cb-pulse 2.5s ease-out infinite;
    pointer-events: none;
  }
  @keyframes cb-pulse {
    0%   { transform: scale(1); opacity: 1; }
    100% { transform: scale(1.4); opacity: 0; }
  }

  /* ── 标签 ── */
  .cb-hint {
    background: linear-gradient(135deg, #58a6ff, #a78bfa);
    border: none;
    border-radius: 6px;
    padding: 0.25rem 0.65rem;
    font-size: 0.72rem;
    font-weight: 600;
    color: #fff;
    letter-spacing: 0.5px;
    margin-bottom: 0.4rem;
    white-space: nowrap;
    box-shadow: 0 2px 10px rgba(88,166,255,0.3);
    pointer-events: none;
  }
  /* ── 气泡按钮 ── */
  .chat-bubble {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: linear-gradient(135deg, #58a6ff, #a78bfa);
    border: none;
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 3px 20px rgba(88,166,255,0.4);
    position: relative;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .chat-bubble:hover {
    transform: scale(1.1);
    box-shadow: 0 5px 28px rgba(88,166,255,0.55);
  }
  .chat-bubble.active {
    box-shadow: 0 5px 28px rgba(167,139,250,0.5);
  }
  .cb-icon { position: absolute; transition: opacity 0.2s, transform 0.2s; }
  .cb-close { opacity: 0; transform: rotate(-90deg); }
  .chat-bubble.active .cb-default { opacity: 0; transform: rotate(90deg); }
  .chat-bubble.active .cb-close { opacity: 1; transform: rotate(0); }

  /* ── 聊天面板 ── */
  .chat-panel {
    position: fixed;
    top: 10rem;
    left: 1.2rem;
    width: 360px;
    max-height: 520px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    box-shadow: 0 8px 40px rgba(0,0,0,0.28);
    z-index: 899;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    opacity: 0;
    transform: translateY(16px) scale(0.96);
    pointer-events: none;
    transition: opacity 0.25s, transform 0.25s;
  }
  .chat-panel.open {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  /* ── 头部 ── */
  .cp-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.8rem 1rem;
    border-bottom: 1px solid var(--border);
    background: var(--bg);
  }
  .cp-title { font-size: 0.85rem; font-weight: 600; }
  .cp-close {
    background: none;
    border: none;
    color: var(--text-muted);
    font-size: 1rem;
    cursor: pointer;
    padding: 0;
    line-height: 1;
    transition: color 0.15s;
  }
  .cp-close:hover { color: var(--text); }

  /* ── 消息区 ── */
  .cp-messages {
    flex: 1;
    overflow-y: auto;
    padding: 0.8rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    scroll-behavior: smooth;
    max-height: 360px;
  }
  .msg { display: flex; gap: 0.5rem; max-width: 100%; }
  .msg-user { flex-direction: row-reverse; }
  .msg-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    flex-shrink: 0;
    background: var(--bg-hover);
  }
  .msg-content {
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--text);
    padding: 0.4rem 0.7rem;
    border-radius: 8px;
    background: var(--bg-hover);
    max-width: 80%;
    white-space: pre-wrap;
    word-break: break-word;
  }
  .msg-user .msg-content {
    background: linear-gradient(135deg, rgba(88,166,255,0.15), rgba(167,139,250,0.1));
  }

  /* ── 输入区 ── */
  .cp-input-wrap {
    display: flex;
    align-items: flex-end;
    gap: 0.5rem;
    padding: 0.7rem 1rem;
    border-top: 1px solid var(--border);
    background: var(--bg);
  }
  .cp-input {
    flex: 1;
    background: var(--bg-hover);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.5rem 0.7rem;
    font-size: 0.85rem;
    color: var(--text);
    resize: none;
    outline: none;
    font-family: inherit;
    line-height: 1.5;
    max-height: 120px;
    transition: border-color 0.15s;
  }
  .cp-input:focus { border-color: var(--c-os); }
  .cp-input::placeholder { color: var(--text-muted); }
  .cp-send {
    background: linear-gradient(135deg, #58a6ff, #a78bfa);
    border: none;
    border-radius: 8px;
    color: #fff;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    flex-shrink: 0;
    transition: opacity 0.15s, transform 0.15s;
  }
  .cp-send:hover { opacity: 0.9; transform: scale(1.05); }
  .cp-send:disabled { opacity: 0.4; cursor: default; transform: none; }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .cb-wrapper { top: 4rem; left: 0.5rem; }
    .chat-panel {
      left: 0.5rem;
      top: 9.5rem;
      width: calc(100vw - 1rem);
      max-height: 60vh;
    }
    .cb-hint { display: none; }
  }
</style>
