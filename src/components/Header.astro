---
const links = [
  { href: '/', label: '首页' },
  { href: '/projects', label: '项目' },
  { href: '/notes', label: '笔记' },
  { href: '/hobbies', label: '爱好' },
  { href: '/quotes', label: '拾句' },
  { href: '/timeline', label: '时间线' },
  { href: '/about', label: '关于' },
];
const currentPath = Astro.url.pathname;
---

<header class="header">
  <div class="header-inner container-wide">
    <a href="/" class="logo">GR</a>
    <nav class="nav" aria-label="主导航">
      {links.map(link => (
        <a href={link.href}
           class={'nav-link' + (currentPath.startsWith(link.href) && link.href !== '/' ? ' active' : '')}
           {...(currentPath.startsWith(link.href) && link.href !== '/' ? { 'aria-current': 'page' } : {})}
        >{link.label}</a>
      ))}
      <button class="theme-toggle" id="theme-toggle" aria-label="切换暗色/亮色模式" title="切换主题">
        <span class="tt-icon tt-moon">🌙</span>
        <span class="tt-icon tt-sun">☀️</span>
      </button>
    </nav>
  </div>
</header>

<style>
  .header {
    border-bottom: 1px solid var(--border);
    background: rgba(11, 14, 20, 0.85);
    backdrop-filter: blur(12px);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
  }
  .logo {
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 1px;
    color: var(--text);
    text-decoration: none;
    padding: 3px 8px;
    border: 2px solid var(--c-os);
    border-radius: 6px;
    line-height: 1;
    transition: all 0.2s;
  }
  .logo:hover {
    box-shadow: 0 0 16px var(--c-os-glow);
    color: var(--c-os);
  }
  .nav { display: flex; gap: 0.25rem; }
  .nav-link {
    font-size: 0.85rem;
    padding: 0.3rem 0.7rem;
    border-radius: 6px;
    color: var(--text-secondary);
    transition: all 0.15s;
    text-decoration: none;
  }
  .nav-link:hover {
    color: var(--text);
    background: var(--bg-hover);
  }
  .nav-link.active {
    color: var(--c-os);
    background: var(--accent-light);
  }

  /* ── Theme Toggle ── */
  .theme-toggle {
    background: none;
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.3rem 0.5rem;
    cursor: pointer;
    font-size: 0.95rem;
    line-height: 1;
    margin-left: 0.4rem;
    transition: border-color 0.2s, background 0.2s;
    display: flex;
    align-items: center;
    gap: 0.2rem;
  }
  .theme-toggle:hover {
    border-color: var(--c-os);
    background: var(--bg-hover);
  }
  .tt-icon { display: inline-block; }
  /* 暗色模式默认显示月亮，隐藏太阳 */
  .tt-sun { display: none; }
  /* 亮色模式切换 */
  [data-theme="light"] .tt-moon { display: none; }
  [data-theme="light"] .tt-sun { display: inline-block; }

  @media (max-width: 520px) {
    .nav { gap: 0.15rem; }
    .nav-link { font-size: 0.78rem; padding: 0.25rem 0.45rem; }
    .theme-toggle { padding: 0.25rem 0.35rem; font-size: 0.85rem; margin-left: 0.15rem; }
  }
</style>
