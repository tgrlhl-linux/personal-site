---
const links = [
  { href: '/', label: '首页' },
  { href: '/projects', label: '项目' },
  { href: '/notes', label: '笔记' },
  { href: '/hobbies', label: '爱好' },
  { href: '/timeline', label: '时间线' },
  { href: '/about', label: '关于' },
];
const currentPath = Astro.url.pathname;
---

<header class="header">
  <div class="header-inner container-wide">
    <a href="/" class="logo">GR</a>
    <nav class="nav">
      {links.map(link => (
        <a href={link.href}
           class={'nav-link' + (currentPath.startsWith(link.href) && link.href !== '/' ? ' active' : '')}>{link.label}</a>
      ))}
    </nav>
  </div>
</header>

<style>
  .header {
    border-bottom: 1px solid var(--border);
    background: rgba(11, 14, 20, 0.85);
    backdrop-filter: blur(12px);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
  }
  .logo {
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 1px;
    color: var(--text);
    text-decoration: none;
    padding: 3px 8px;
    border: 2px solid var(--c-os);
    border-radius: 6px;
    line-height: 1;
    transition: all 0.2s;
  }
  .logo:hover {
    box-shadow: 0 0 16px var(--c-os-glow);
    color: var(--c-os);
  }
  .nav { display: flex; gap: 0.25rem; }
  .nav-link {
    font-size: 0.85rem;
    padding: 0.3rem 0.7rem;
    border-radius: 6px;
    color: var(--text-secondary);
    transition: all 0.15s;
    text-decoration: none;
  }
  .nav-link:hover {
    color: var(--text);
    background: var(--bg-hover);
  }
  .nav-link.active {
    color: var(--c-os);
    background: var(--accent-light);
  }

  @media (max-width: 520px) {
    .nav { gap: 0; }
    .nav-link { font-size: 0.78rem; padding: 0.25rem 0.5rem; }
  }
</style>
