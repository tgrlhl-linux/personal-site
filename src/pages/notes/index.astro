---
import Base from '../../layouts/Base.astro';
import { query } from '../../db/mysql';

const search = Astro.url.searchParams.get('q') || '';
const courseFilter = Astro.url.searchParams.get('course') || '';

let where = "type = 'note' AND status = 'published'";
const params = [];
if (search) {
  where += ' AND (title LIKE ? OR content LIKE ?)';
  params.push(`%${search}%`, `%${search}%`);
}
if (courseFilter) {
  where += ' AND course = ?';
  params.push(courseFilter);
}

const notes = await query(
  `SELECT id, title, slug, excerpt, course, tags, created_at
   FROM notes WHERE ${where}
   ORDER BY ${courseFilter ? 'title ASC' : 'created_at DESC'}`,
  params
);

const courses = await query(
  `SELECT DISTINCT course FROM notes WHERE type='note' AND status='published' AND course IS NOT NULL AND course != '' ORDER BY course`
);

const courseColors = {
  '操作系统': '#58a6ff',
  '数据库原理': '#3fb950',
  '概率论与数理统计': '#d29922',
  '习近平新时代中国特色社会主义思想概论': '#bc8cff',
};
const courseGlows = {
  '操作系统': 'rgba(88,166,255,0.12)',
  '数据库原理': 'rgba(63,185,80,0.12)',
  '概率论与数理统计': 'rgba(210,153,34,0.12)',
  '习近平新时代中国特色社会主义思想概论': 'rgba(188,140,255,0.12)',
};
function cc(c) { return courseColors[c] || '#58a6ff'; }
function cg(c) { return courseGlows[c] || 'rgba(88,166,255,0.12)'; }

// Group notes by course
const grouped = {};
for (const n of notes) {
  const c = n.course || '未分类';
  if (!grouped[c]) grouped[c] = [];
  grouped[c].push(n);
}

// Sort groups: maintain course order
const courseOrder = ['操作系统', '数据库原理', '概率论与数理统计', '习近平新时代中国特色社会主义思想概论'];
const sortedGroups = Object.entries(grouped).sort((a, b) => {
  const ia = courseOrder.indexOf(a[0]), ib = courseOrder.indexOf(b[0]);
  return (ia === -1 ? 99 : ia) - (ib === -1 ? 99 : ib);
});

// Latest 3 notes
const latestNotes = [...notes].sort((a, b) => new Date(b.created_at) - new Date(a.created_at)).slice(0, 3);

// All unique tags
const allTags = [...new Set(notes.flatMap(n => {
  try { return JSON.parse(n.tags || '[]'); } catch { return []; }
}))];
---

<Base title="笔记" description="课程笔记与技术思考" wide={true}>
  <!-- Header -->
  <div class="np-header">
    <div>
      <h1>笔记</h1>
      <div class="np-sub">{notes.length} 篇笔记 · {courses.length} 个分类</div>
    </div>
    <a href="/rss.xml" class="np-rss" target="_blank" rel="noopener" title="RSS 订阅">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><circle cx="4" cy="20" r="3"/><path d="M4 11a9 9 0 0 1 9 9h3a12 12 0 0 0-12-12v3zm0-7a16 16 0 0 1 16 16h3a19 19 0 0 0-19-19v3z"/></svg>
      <span>RSS</span>
    </a>
  </div>

  <!-- Toolbar -->
  <div class="np-toolbar">
    <div class="np-search">
      <span class="np-search-icon">⌕</span>
      <form method="GET" action="/notes" style="flex:1">
        <input type="text" name="q" placeholder="搜索笔记..." value={search} class="np-search-input">
        {courseFilter && <input type="hidden" name="course" value={courseFilter}>}
      </form>
    </div>
    <div class="np-filters">
      <a href="/notes" class={'np-pill' + (!courseFilter ? ' active' : '')}>全部</a>
      {courses.map(c => (
        <a href={`/notes?course=${encodeURIComponent(c.course)}`
          } class={'np-pill' + (courseFilter === c.course ? ' active' : '') + ' pill-' + c.course}
          style={courseFilter !== c.course ? `--pill-color:${cc(c.course)};--pill-glow:${cg(c.course)}` : ''}
        >{c.course}</a>
      ))}
    </div>
  </div>

  <!-- Empty state -->
  {notes.length === 0 ? (
    <div class="np-empty">
      <p>还没有笔记</p>
      {search && <p class="np-empty-hint">没有找到匹配「{search}」的笔记</p>}
    </div>
  ) : (
    <!-- Card layout (参考项目页) -->
    <div class="nc-layout">

      <!-- Stats row -->
      <div class="nc-stats" data-reveal="bottom">
        <div class="nc-stat" style="--sc:var(--c-os);--sb:rgba(88,166,255,0.2)">
          <div class="nc-stat-icon">📘</div>
          <div class="nc-stat-num">{notes.length}</div>
          <div class="nc-stat-label">笔记总数</div>
        </div>
        <div class="nc-stat" style="--sc:var(--c-db);--sb:rgba(63,185,80,0.2)">
          <div class="nc-stat-icon">📗</div>
          <div class="nc-stat-num">{courses.length}</div>
          <div class="nc-stat-label">课程分类</div>
        </div>
        <div class="nc-stat" style="--sc:var(--c-prob);--sb:rgba(210,153,34,0.2)">
          <div class="nc-stat-icon">🏆</div>
          <div class="nc-stat-num">{Math.max(...sortedGroups.map(g => g[1].length), 0)}</div>
          <div class="nc-stat-label">最多笔记</div>
        </div>
        <div class="nc-stat" style="--sc:var(--c-pol);--sb:rgba(188,140,255,0.2)">
          <div class="nc-stat-icon">🕐</div>
          <div class="nc-stat-num">{latestNotes[0] ? new Date(latestNotes[0].created_at).toLocaleDateString('zh-CN', { month: '2-digit', day: '2-digit' }) : '--'}</div>
          <div class="nc-stat-label">最后更新</div>
        </div>
      </div>

      <!-- Cards grouped by course (参考项目页分组设计) -->
      <div class="nc-groups">
        {sortedGroups.map(([course, items]) => {
          const color = cc(course);
          return (
            <div class="nc-group" style={`--cc:${color}`} data-reveal="bottom" data-delay="100">
              <div class="nc-grp-hd">
                <span class="nc-grp-dot" style={`background:${color};box-shadow:0 0 6px ${color}`}></span>
                <span class="nc-grp-name">{course}</span>
                <span class="nc-grp-count">{items.length}</span>
              </div>
              <div class="nc-grp-body">
                {items.map((n, i) => {
                  const tagList = (() => { try { return JSON.parse(n.tags || '[]'); } catch { return []; } })();
                  const shortTitle = n.title.replace(/^.*?·\s*/, '');
                  const dateStr = new Date(n.created_at).toLocaleDateString('zh-CN', { month: 'short', day: 'numeric' });
                  return (
                    <a href={`/notes/${n.id}`} class="nc-card" style={`--cc:${color}`} data-reveal="bottom" data-delay={`${i * 50}`}>
                      <div class="ncc-left">
                        <span class="ncc-num">{String(i + 1).padStart(2, '0')}</span>
                        <span class="ncc-title">{shortTitle}</span>
                        <div class="ncc-tags">
                          {tagList.slice(0, 3).map(t => <span class="ncc-tag">{t}</span>)}
                        </div>
                      </div>
                      <div class="ncc-right">
                        <div class="ncc-excerpt">{n.excerpt || shortTitle}</div>
                        <div class="ncc-meta">
                          <span class="ncc-course" style={`color:${color}`}>{course}</span>
                          <span class="ncc-date">{dateStr}</span>
                        </div>
                      </div>
                      <div class="ncc-arrow">→</div>
                    </a>
                  );
                })}
              </div>
            </div>
          );
        })}
      </div>

      <!-- Side row: latest + tags -->
      <div class="nc-sidebar">
        <div class="nc-latest" data-reveal="bottom" data-delay="150">
          <div class="nc-latest-label">⚡ 最近更新</div>
          {latestNotes.map(n => {
            const c = n.course || '';
            return (
              <a href={`/notes/${n.id}`} class="ncl-item">
                <span class="ncl-course" style={`--c-bg:${cg(c)};--c-color:${cc(c)}`}>{c}</span>
                <div class="ncl-title">{n.title.replace(/^.*?·\s*/, '')}</div>
                <div class="ncl-date">{new Date(n.created_at).toLocaleDateString('zh-CN')}</div>
              </a>
            );
          })}
        </div>
        <div class="nc-tags-card" data-reveal="bottom" data-delay="200">
          <div class="nc-tags-label">🏷️ 标签</div>
          <div class="nc-tags-body">
            {allTags.slice(0, 10).map(t => <span class="nc-tag">{t}</span>)}
          </div>
        </div>
      </div>

    </div>
  )}
</Base>

<style>
  /* ── Page header ── */
  .np-header { margin-bottom: 1.2rem; display: flex; justify-content: space-between; align-items: flex-start; }
  .np-header h1 { font-size: 1.6rem; margin: 0; }
  .np-sub { font-size: 0.82rem; color: var(--text-muted); margin-top: 0.1rem; }
  .np-rss {
    display: flex; align-items: center; gap: 0.3rem;
    font-size: 0.72rem; color: var(--text-muted); text-decoration: none;
    padding: 0.3rem 0.5rem; border: 1px solid var(--border); border-radius: 6px;
    transition: all 0.2s; white-space: nowrap;
  }
  .np-rss:hover { color: #f97316; border-color: #f97316; background: rgba(249,115,22,0.06); }

  /* ── Toolbar ── */
  .np-toolbar { display: flex; gap: 0.75rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
  .np-search {
    flex: 1; min-width: 220px; position: relative;
    display: flex; align-items: center;
  }
  .np-search-icon {
    position: absolute; left: 0.8rem;
    color: var(--text-muted); font-size: 1.1rem; pointer-events: none;
  }
  .np-search-input {
    width: 100%;
    padding: 0.55rem 0.8rem 0.55rem 2.4rem;
    border: 1px solid var(--border);
    border-radius: 10px;
    font-size: 0.88rem;
    background: var(--bg-card);
    color: var(--text);
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .np-search-input::placeholder { color: var(--text-muted); }
  .np-search-input:focus {
    border-color: var(--c-os);
    box-shadow: 0 0 0 3px var(--c-os-glow);
  }
  .np-filters { display: flex; gap: 0.35rem; flex-wrap: wrap; align-items: center; }
  .np-pill {
    padding: 0.35rem 0.9rem;
    border-radius: 20px;
    border: 1px solid var(--border);
    background: var(--bg-card);
    font-size: 0.8rem;
    cursor: pointer;
    color: var(--text-secondary);
    text-decoration: none;
    transition: all 0.15s;
  }
  .np-pill:hover {
    border-color: var(--pill-color, var(--text-muted));
    color: var(--pill-color, var(--text));
  }
  .np-pill.active {
    background: rgba(255,255,255,0.9);
    color: #0b0e14;
    border-color: transparent;
  }

  /* ── Card Layout（参考项目页） ── */
  .nc-layout { max-width: var(--max-width-wide); margin: 0 auto; }

  /* Stats row */
  .nc-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .nc-stat {
    background: var(--bg-card);
    border: 1px solid var(--sb);
    border-radius: var(--radius);
    padding: 0.8rem 0.6rem;
    text-align: center;
  }
  .nc-stat-icon { font-size: 1rem; margin-bottom: 0.15rem; }
  .nc-stat-num {
    font-size: 1.5rem; font-weight: 700; color: var(--sc); line-height: 1.1;
    letter-spacing: -0.03em;
  }
  .nc-stat-label { font-size: 0.7rem; color: var(--text-muted); margin-top: 0.05rem; }

  /* Groups container */
  .nc-groups { display: flex; flex-direction: column; gap: 1.2rem; margin-bottom: 1.2rem; }
  .nc-group {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .nc-grp-hd {
    padding: 0.7rem 1.2rem 0.3rem;
    display: flex; align-items: center; gap: 0.4rem;
  }
  .nc-grp-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .nc-grp-name { font-weight: 600; font-size: 0.9rem; }
  .nc-grp-count {
    font-size: 0.65rem; color: var(--text-muted);
    background: var(--bg-hover); padding: 0.05em 0.45em; border-radius: 6px;
  }
  .nc-grp-body { padding: 0.3rem 0.8rem 0.8rem; display: flex; flex-direction: column; gap: 0.5rem; }

  /* Note cards (参考 pg-card from projects) */
  .nc-card {
    display: grid;
    grid-template-columns: 200px 1fr 2rem;
    gap: 0;
    align-items: center;
    padding: 0;
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: var(--text);
    background: var(--bg);
    border: 1px solid var(--border);
    overflow: hidden;
    transition: box-shadow 0.2s, transform 0.15s, border-color 0.2s;
    position: relative;
  }
  .nc-card:hover {
    box-shadow: 0 0 0 1px var(--cc), var(--shadow-hover);
    transform: translateY(-2px);
    border-color: var(--cc);
  }
  .ncc-left {
    background: linear-gradient(135deg, color-mix(in srgb, var(--cc) 8%, transparent), transparent);
    padding: 0.75rem 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    min-height: 80px;
    border-right: 1px solid var(--border);
  }
  .ncc-num {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-muted);
    letter-spacing: 0.03em;
  }
  .ncc-title {
    font-size: 0.88rem;
    font-weight: 600;
    line-height: 1.3;
  }
  .ncc-tags {
    display: flex;
    gap: 0.2rem;
    flex-wrap: wrap;
    margin-top: 0.05rem;
  }
  .ncc-tag {
    font-size: 0.6rem;
    padding: 0.1em 0.4em;
    background: var(--bg-hover);
    border-radius: 3px;
    color: var(--text-secondary);
    white-space: nowrap;
  }
  .ncc-right {
    padding: 0.75rem 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    min-height: 80px;
    justify-content: center;
  }
  .ncc-excerpt {
    font-size: 0.8rem;
    color: var(--text-secondary);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .ncc-meta {
    display: flex;
    gap: 0.6rem;
    align-items: center;
    margin-top: 0.1rem;
  }
  .ncc-course {
    font-size: 0.65rem;
    padding: 0.1em 0.5em;
    border-radius: 4px;
    background: color-mix(in srgb, var(--cc) 15%, transparent);
  }
  .ncc-date { font-size: 0.65rem; color: var(--text-muted); }
  .ncc-arrow {
    font-size: 1rem;
    color: var(--text-muted);
    padding-right: 0.6rem;
    opacity: 0.3;
    transition: opacity 0.2s, transform 0.2s;
  }
  .nc-card:hover .ncc-arrow {
    opacity: 1;
    transform: translateX(3px);
    color: var(--cc);
  }

  /* Sidebar: latest + tags */
  .nc-sidebar {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }
  .nc-latest, .nc-tags-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.2rem;
  }
  .nc-latest-label, .nc-tags-label {
    font-size: 0.65rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: 1px; color: var(--text-muted); margin-bottom: 0.5rem;
  }
  .ncl-item {
    display: block; padding: 0.4rem 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none; color: var(--text);
    transition: opacity 0.1s;
  }
  .ncl-item:last-of-type { border-bottom: none; }
  .ncl-item:hover { opacity: 0.85; }
  .ncl-course {
    font-size: 0.65rem; padding: 0.1em 0.5em; border-radius: 4px;
    display: inline-block; margin-bottom: 0.1rem;
    background: var(--c-bg); color: var(--c-color);
  }
  .ncl-title { font-size: 0.85rem; font-weight: 500; }
  .ncl-date { font-size: 0.68rem; color: var(--text-muted); margin-top: 0.05rem; }
  .nc-tags-body { display: flex; flex-wrap: wrap; gap: 0.35rem; }
  .nc-tag {
    font-size: 0.68rem; padding: 0.15em 0.5em;
    background: var(--bg-hover); border-radius: 4px;
    color: var(--text-secondary);
  }

  /* Empty state */
  .np-empty { text-align: center; padding: 4rem 0; color: var(--text-muted); }
  .np-empty-hint { font-size: 0.85rem; margin-top: 0.5rem; }

  /* Responsive */
  @media (max-width: 900px) {
    .nc-stats { grid-template-columns: repeat(2, 1fr); }
    .nc-card { grid-template-columns: 160px 1fr 1.5rem; }
    .nc-sidebar { grid-template-columns: 1fr; }
  }
  @media (max-width: 600px) {
    .nc-stats { grid-template-columns: repeat(2, 1fr); }
    .nc-card { grid-template-columns: 1fr; }
    .ncc-left {
      border-right: none;
      border-bottom: 1px solid var(--border);
      min-height: auto;
      padding: 0.5rem 0.7rem;
    }
    .ncc-right { padding: 0.5rem 0.7rem; min-height: auto; }
    .ncc-arrow { display: none; }
    .nc-sidebar { grid-template-columns: 1fr; }
    .np-filters { order: -1; width: 100%; }
  }
</style>
