---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import { query } from '../../db/mysql';

const id = parseInt(Astro.params.id);
let note = null;
let error = null;

if (!id) {
  error = '无效的笔记 ID';
} else {
  const rows = await query('SELECT * FROM notes WHERE id = ?', [id]);
  if (rows.length === 0) error = '笔记不存在';
  else note = rows[0];
}

const rawTags = note?.tags;
const tags = Array.isArray(rawTags) ? rawTags :
  (() => { try { return JSON.parse(rawTags || '[]'); } catch { return (rawTags || '').split(',').map(t => t.trim()); } })();
const tagString = Array.isArray(rawTags) ? rawTags.join(' · ') :
  (() => { try { return JSON.parse(rawTags || '[]').join(' · '); } catch { return (rawTags || '').split(',').join(' · '); } })();

const courseColors = {
  '操作系统': '#58a6ff',
  '数据库原理': '#3fb950',
  '概率论与数理统计': '#d29922',
  '习近平新时代中国特色社会主义思想概论': '#bc8cff',
};
const courseColor = courseColors[note?.course] || '#58a6ff';
---

{error ? (
  <Base title="笔记不存在">
    <div class="page-header">
      <h1>笔记不存在</h1>
      <p><a href="/notes">← 返回笔记列表</a></p>
    </div>
  </Base>
) : (
  <Base title={note.title} description={tagString}>
    <article class="post">
      <header class="post-header" style={`--cc:${courseColor}`}>
        <div class="post-meta">
          <time class="meta">
            {new Date(note.created_at).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          {note.course && <span class="tag course-tag" style={`background:${courseColor}15;color:${courseColor};border:1px solid ${courseColor}30`}>{note.course}</span>}
        </div>
        <h1>{note.title}</h1>
        <div class="post-tags">
          {tags.map(t => <span class="tag">{t}</span>)}
        </div>
      </header>

      <div class="post-content">
        <div id="content">{note.content || ''}</div>
      </div>

      <nav class="post-nav">
        <a href="/notes" class="btn">← 返回笔记列表</a>
      </nav>
    </article>

    <script>
      import { marked } from 'marked';
      marked.setOptions({ breaks: true, gfm: true });
      const content = document.getElementById('content');
      if (content) {
        const md = content.textContent;
        content.innerHTML = marked.parse(md);
      }
    </script>
  </Base>
)}

<style>
  .post-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }
  .post-meta { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem; }
  .post-meta .meta { margin: 0; }
  .post-header h1 { font-size: 1.8rem; margin-bottom: 0.6rem; }
  .post-tags { display: flex; flex-wrap: wrap; gap: 0.3rem; }
  .post-content { font-size: 1rem; line-height: 1.8; }
  .post-content h1, .post-content h2, .post-content h3 { margin-top: 2rem; margin-bottom: 0.5rem; }
  .post-content h1 { font-size: 1.6rem; }
  .post-content h2 { font-size: 1.3rem; }
  .post-content h3 { font-size: 1.1rem; }
  .post-content p { margin-bottom: 0.8rem; }
  .post-content ul { margin-left: 1.5rem; margin-bottom: 0.8rem; }
  .post-content li { margin-bottom: 0.3rem; }
  .post-content code { font-family: var(--font-mono); font-size: 0.85em; background: var(--bg-hover); padding: 0.15em 0.4em; border-radius: 3px; color: #f0c674; }
  .post-content pre { background: var(--bg-raised); padding: 1rem; border-radius: var(--radius-sm); overflow-x: auto; margin: 1rem 0; border: 1px solid var(--border); }
  .post-content pre code { background: none; padding: 0; color: inherit; }
  .post-content blockquote { border-left: 3px solid var(--cc, var(--c-os)); padding: 0.5rem 1rem; margin: 1rem 0; color: var(--text-secondary); background: var(--bg-hover); border-radius: 0 var(--radius-sm) var(--radius-sm) 0; }
  .post-content table { width: 100%; border-collapse: collapse; margin: 1rem 0; font-size: 0.9rem; }
  .post-content th, .post-content td { border: 1px solid var(--border); padding: 0.5rem 0.8rem; text-align: left; }
  .post-content th { background: var(--bg-hover); font-weight: 600; }
  .post-content tr:nth-child(even) td { background: rgba(255,255,255,0.02); }
  .post-content svg { max-width: 100%; height: auto; margin: 1rem auto; display: block; }
  .post-content img { max-width: 100%; height: auto; border-radius: var(--radius-sm); margin: 1rem auto; display: block; }
  .post-content hr { border: none; border-top: 1px solid var(--border); margin: 1.5rem 0; }
  .post-content ol { margin-left: 1.5rem; margin-bottom: 0.8rem; }
  .post-nav { margin-top: 3rem; }
</style>
