---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import { query } from '../../db/mysql';

const id = parseInt(Astro.params.id);
let note = null;
let error = null;

if (!id) {
  error = '无效的笔记 ID';
} else {
  const rows = await query('SELECT * FROM notes WHERE id = ?', [id]);
  if (rows.length === 0) error = '笔记不存在';
  else note = rows[0];
}
---

{error ? (
  <Base title="笔记不存在">
    <div class="page-header">
      <h1>笔记不存在</h1>
      <p><a href="/notes">← 返回笔记列表</a></p>
    </div>
  </Base>
) : (
  <Base title={note.title} description={(JSON.parse(note.tags || '[]') || []).join(' · ')}>
    <article class="post">
      <header class="post-header">
        <div class="post-meta">
          <time class="meta">
            {new Date(note.created_at).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          {note.course && <span class="tag">{note.course}</span>}
        </div>
        <h1>{note.title}</h1>
        <div class="post-tags">
          {JSON.parse(note.tags || '[]').map(t => <span class="tag">{t}</span>)}
        </div>
      </header>

      <div class="post-content">
        <div id="content">{note.content || ''}</div>
      </div>

      <nav class="post-nav">
        <a href="/notes" class="btn">← 返回笔记列表</a>
      </nav>
    </article>

    <script>
      // Simple Markdown to HTML renderer
      const content = document.getElementById('content');
      if (content) {
        let md = content.textContent;
        let html = md
          .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
          .replace(/```(\w*)\n([\s\S]*?)```/g, '<pre><code>$2</code></pre>')
          .replace(/`([^`]+)`/g, '<code>$1</code>')
          .replace(/^### (.+)$/gm, '<h3>$1</h3>')
          .replace(/^## (.+)$/gm, '<h2>$1</h2>')
          .replace(/^# (.+)$/gm, '<h1>$1</h1>')
          .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
          .replace(/\*(.+?)\*/g, '<em>$1</em>')
          .replace(/^- (.+)$/gm, '<li>$1</li>')
          .replace(/(<li>.*\n?)+/g, m => '<ul>' + m + '</ul>')
          .replace(/\n\n/g, '</p><p>')
          .replace(/\n/g, '<br>');
        content.innerHTML = '<p>' + html + '</p>';
      }
    </script>
  </Base>
)}

<style>
  .post-header { margin-bottom: 2rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border); }
  .post-meta { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem; }
  .post-meta .meta { margin: 0; }
  .post-header h1 { font-size: 1.8rem; margin-bottom: 0.6rem; }
  .post-tags { display: flex; flex-wrap: wrap; }
  .post-content { font-size: 1rem; line-height: 1.8; }
  .post-content h1, .post-content h2, .post-content h3 { margin-top: 2rem; margin-bottom: 0.5rem; }
  .post-content h1 { font-size: 1.6rem; }
  .post-content h2 { font-size: 1.3rem; }
  .post-content h3 { font-size: 1.1rem; }
  .post-content p { margin-bottom: 0.8rem; }
  .post-content ul { margin-left: 1.5rem; margin-bottom: 0.8rem; }
  .post-content li { margin-bottom: 0.3rem; }
  .post-content code { font-family: var(--font-mono); font-size: 0.85em; background: var(--bg-hover); padding: 0.15em 0.4em; border-radius: 3px; }
  .post-content pre { background: var(--bg-hover); padding: 1rem; border-radius: var(--radius); overflow-x: auto; margin: 1rem 0; }
  .post-content pre code { background: none; padding: 0; }
  .post-content blockquote { border-left: 3px solid var(--accent-light); padding: 0.5rem 1rem; margin: 1rem 0; color: var(--text-secondary); background: var(--bg-hover); border-radius: 0 var(--radius) var(--radius) 0; }
  .post-content table { width: 100%; border-collapse: collapse; margin: 1rem 0; font-size: 0.9rem; }
  .post-content th, .post-content td { border: 1px solid var(--border); padding: 0.5rem 0.8rem; text-align: left; }
  .post-content th { background: var(--bg-hover); font-weight: 600; }
  .post-nav { margin-top: 3rem; }
</style>
