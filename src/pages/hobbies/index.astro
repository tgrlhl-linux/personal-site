---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const hobbies = (await getCollection('hobbies'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Base title="爱好" description="生活中的热爱">
  <div class="page-header">
    <h1>爱好</h1>
    <p>代码之外，还有更大的世界</p>
  </div>

  {hobbies.length === 0 ? (
    <div class="empty-state">
      <p>还没有添加爱好内容</p>
    </div>
  ) : (
    <div class="grid hobbies-grid">
      {hobbies.map(h => (
        <a href={`/hobbies/${h.id}`} class="card hobby-card">
          <h2>{h.data.title}</h2>
          <p>{h.data.description}</p>
          <div class="hobby-tags">
            {h.data.tags.map(t => <span class="tag">{t}</span>)}
          </div>
        </a>
      ))}
    </div>
  )}
</Base>

<style>
  .hobbies-grid { grid-template-columns: 1fr; }
  @media (min-width: 640px) {
    .hobbies-grid { grid-template-columns: repeat(2, 1fr); }
  }
  .hobby-card {
    text-decoration: none;
    color: var(--text);
    padding: 1.5rem;
  }
  .hobby-card:hover { color: var(--text); }
  .hobby-card h2 {
    font-size: 1.2rem;
    margin: 0 0 0.5rem;
  }
  .hobby-card p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin: 0 0 0.8rem;
  }
  .hobby-tags { display: flex; flex-wrap: wrap; }
  .empty-state {
    text-align: center;
    padding: 4rem 0;
    color: var(--text-muted);
  }
</style>
