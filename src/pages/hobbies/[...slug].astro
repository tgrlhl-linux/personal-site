---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import { query } from '../../db/mysql';
import { marked } from 'marked';

marked.setOptions({ breaks: true, gfm: true });

const slug = Astro.params.slug;

let error = null;
let hobby = null;
let renderedContent = '';

if (!slug) {
  error = '无效的 ID';
} else {
  const rows = await query("SELECT * FROM notes WHERE type='hobby' AND slug = ?", [slug]);
  if (rows.length === 0) error = '内容不存在';
  else {
    hobby = rows[0];
    renderedContent = marked.parse(hobby.content || '');
  }
}

const tagList = hobby ? (() => {
  if (Array.isArray(hobby.tags)) return hobby.tags;
  try { return JSON.parse(hobby.tags || '[]'); } catch { return []; }
})() : [];
---

{error ? (
  <Base title="内容不存在">
    <div class="page-header">
      <h1>内容不存在</h1>
      <p><a href="/hobbies">← 返回爱好列表</a></p>
    </div>
  </Base>
) : (
  <Base title={hobby.title}>
    <article class="post">
      <header class="post-header">
        <div class="post-meta">
          <time class="meta">{new Date(hobby.created_at).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long' })}</time>
        </div>
        <h1>{hobby.title}</h1>
        <div class="post-tags">
          {tagList.map(t => <span class="tag">{t}</span>)}
        </div>
      </header>

      <div class="post-content" set:html={renderedContent}></div>

      <nav class="post-nav">
        <a href="/hobbies" class="btn">← 返回爱好列表</a>
      </nav>
    </article>
  </Base>
)}

<style>
  .post-header { margin-bottom: 2rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border); }
  .post-meta { margin-bottom: 0.8rem; }
  .post-meta .meta { margin: 0; }
  .post-header h1 { font-size: 1.8rem; margin-bottom: 0.6rem; }
  .post-tags { display: flex; flex-wrap: wrap; }

  .post-content { font-size: 1rem; line-height: 1.8; }
  .post-content h1, .post-content h2, .post-content h3 { margin-top: 2rem; }
  .post-content h1 { font-size: 1.6rem; }
  .post-content h2 { font-size: 1.3rem; }
  .post-content h3 { font-size: 1.1rem; }
  .post-content p { margin-bottom: 0.8rem; }
  .post-content ul { margin-left: 1.5rem; margin-bottom: 0.8rem; }
  .post-content li { margin-bottom: 0.3rem; }
  .post-content code { font-family: var(--font-mono); font-size: 0.85em; background: var(--bg-hover); padding: 0.15em 0.4em; border-radius: 3px; }
  .post-content pre { background: var(--bg-raised); padding: 1rem; border-radius: var(--radius-sm); overflow-x: auto; margin: 1rem 0; border: 1px solid var(--border); }
  .post-content pre code { background: none; padding: 0; }
  .post-content blockquote { border-left: 3px solid var(--c-os); padding: 0.5rem 1rem; margin: 1rem 0; color: var(--text-secondary); background: var(--bg-hover); border-radius: 0 var(--radius-sm) var(--radius-sm) 0; }
  .post-content img { max-width: 100%; border-radius: var(--radius-sm); margin: 1rem 0; }
  .post-nav { margin-top: 3rem; }
</style>
