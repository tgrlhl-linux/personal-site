---
export const prerender = true;

import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const hobbies = await getCollection('hobbies');
  return hobbies.map(h => ({
    params: { slug: h.id },
    props: { entry: h },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { title, description, date, tags } = entry.data;
---

<Base title={title} description={description}>
  <article class="post">
    <header class="post-header">
      <div class="post-meta">
        <time class="meta">{date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long' })}</time>
      </div>
      <h1>{title}</h1>
      <p class="post-desc">{description}</p>
      <div class="post-tags">
        {tags.map(t => <span class="tag">{t}</span>)}
      </div>
    </header>
    <div class="post-content">
      <Content />
    </div>
    <nav class="post-nav">
      <a href="/hobbies" class="btn">← 返回爱好列表</a>
    </nav>
  </article>
</Base>

<style>
  .post-header { margin-bottom: 2rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border); }
  .post-meta { margin-bottom: 0.8rem; }
  .post-meta .meta { margin: 0; }
  .post-header h1 { font-size: 1.8rem; margin-bottom: 0.6rem; }
  .post-desc { color: var(--text-secondary); font-size: 1rem; margin-bottom: 1rem; }
  .post-tags { display: flex; flex-wrap: wrap; }

  .post-content { font-size: 1rem; line-height: 1.8; }
  .post-content h2 { margin-top: 2rem; }
  .post-content h3 { margin-top: 1.5rem; }
  .post-content ul, .post-content ol { margin-left: 1.5rem; }
  .post-content li { margin-bottom: 0.3rem; }
  .post-content img { border-radius: var(--radius); margin: 1rem 0; }

  .post-nav { margin-top: 3rem; }
</style>
