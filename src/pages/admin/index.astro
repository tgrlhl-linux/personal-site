---
import { verifyToken, COOKIE_NAME } from '../../lib/auth.js';
const token = Astro.cookies.get(COOKIE_NAME)?.value;
const username = token ? verifyToken(token) : null;
if (!username) return Astro.redirect('/admin/login');
---

<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>管理概览</title>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Noto Sans SC", sans-serif; background:#f5f4f0; color:#1c1a18; }
    .layout { display:flex; min-height:100vh; }
    .side { width:200px; background:#1a1a24; color:#c8c8d0; display:flex; flex-direction:column; flex-shrink:0; position:sticky; top:0; height:100vh; }
    .side-logo { padding:1.2rem; font-size:0.85rem; font-weight:600; border-bottom:1px solid rgba(255,255,255,0.08); }
    .side-nav { flex:1; padding:0.5rem 0; }
    .side-nav a { display:block; padding:0.6rem 1.2rem; font-size:0.85rem; color:#9a9aa8; text-decoration:none; border-left:2px solid transparent; }
    .side-nav a:hover { background:rgba(255,255,255,0.04); color:#e8e8f0; }
    .side-nav a.active { background:rgba(255,255,255,0.06); color:#fff; border-left-color:#c17f59; }
    .side-foot { padding:1rem 1.2rem; border-top:1px solid rgba(255,255,255,0.08); font-size:0.78rem; }
    .side-foot a { color:#7a7a8a; text-decoration:none; }
    .side-foot a:hover { color:#c17f59; }
    .main { flex:1; padding:2rem; max-width:900px; }
    .hd { display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem; }
    .hd h1 { font-size:1.4rem; font-weight:600; margin:0; }
    .stats { display:grid; grid-template-columns:repeat(4,1fr); gap:1rem; margin-bottom:2rem; }
    .stat { background:#fff; border:1px solid rgba(0,0,0,0.06); border-radius:8px; padding:1.5rem; text-align:center; }
    .stat-num { font-size:2rem; font-weight:700; }
    .stat-label { font-size:0.8rem; color:#8a8a9a; margin-top:0.2rem; }
    .stat.s-note .stat-num { color:#c17f59; }
    .stat.s-project .stat-num { color:#f0883e; }
    .stat.s-hobby .stat-num { color:#3fb950; }
    .stat.s-total .stat-num { color:#1a1a24; }
    .card { background:#fff; border:1px solid rgba(0,0,0,0.06); border-radius:8px; padding:1.5rem; }
    .card h2 { font-size:1rem; font-weight:600; margin-bottom:0.8rem; }
    .item { display:flex; justify-content:space-between; padding:0.5rem 0; border-bottom:1px solid rgba(0,0,0,0.04); }
    .item:last-child { border:none; }
    .item a { color:#1c1a18; text-decoration:none; font-size:0.9rem; }
    .item a:hover { color:#c17f59; }
    .item .date { font-size:0.78rem; color:#8a8a9a; }
    .item .type { font-size:0.7rem; padding:0.1em 0.4em; border-radius:3px; }
    .t-note { background:#ede3d8; color:#c17f59; }
    .t-project { background:#fef3e2; color:#f0883e; }
    .t-hobby { background:#e6f4ea; color:#3fb950; }
    .btn { padding:0.5rem 1.2rem; border-radius:4px; font-size:0.85rem; cursor:pointer; border:none; text-decoration:none; display:inline-block; }
    .btn-pri { background:#c17f59; color:#fff; }
    .btn-pri:hover { opacity:0.9; }
    .loading { color:#8a8a9a; font-size:0.85rem; padding:1rem 0; }
  </style>
</head>
<body>
<div class="layout">
  <aside class="side">
    <div class="side-logo">管理后台</div>
    <nav class="side-nav">
      <a href="/admin" class="active">概览</a>
      <a href="/admin/notes">内容</a>
    </nav>
    <div class="side-foot">
      <a href="/">查看网站</a>
    </div>
  </aside>
  <main class="main">
    <div class="hd">
      <h1>概览</h1>
      <a href="/admin/notes/new" class="btn btn-pri">写笔记</a>
    </div>

    <div class="stats">
      <div class="stat s-note"><div class="stat-num" id="noteCount">-</div><div class="stat-label">笔记</div></div>
      <div class="stat s-project"><div class="stat-num" id="projectCount">-</div><div class="stat-label">项目</div></div>
      <div class="stat s-hobby"><div class="stat-num" id="hobbyCount">-</div><div class="stat-label">爱好</div></div>
      <div class="stat s-total"><div class="stat-num" id="totalCount">-</div><div class="stat-label">总计</div></div>
    </div>

    <div class="card">
      <h2>最近更新</h2>
      <div id="recentItems"><div class="loading">加载中...</div></div>
    </div>
  </main>
</div>

<script>
async function loadDashboard() {
  // 分别获取各类别总数
  const [notesRes, projectsRes, hobbiesRes, allRes] = await Promise.all([
    fetch('/api/contents?type=note&limit=1'),
    fetch('/api/contents?type=project&limit=1'),
    fetch('/api/contents?type=hobby&limit=1'),
    fetch('/api/contents?limit=10'),
  ]);
  const notesData = await notesRes.json();
  const projectsData = await projectsRes.json();
  const hobbiesData = await hobbiesRes.json();
  const allData = await allRes.json();

  var noteTotal = notesData.total || 0;
  var projectTotal = projectsData.total || 0;
  var hobbyTotal = hobbiesData.total || 0;

  document.getElementById('noteCount').textContent = noteTotal;
  document.getElementById('projectCount').textContent = projectTotal;
  document.getElementById('hobbyCount').textContent = hobbyTotal;
  document.getElementById('totalCount').textContent = noteTotal + projectTotal + hobbyTotal;

  var items = allData.contents || [];
  var container = document.getElementById('recentItems');
  if (items.length === 0) {
    container.innerHTML = '<div style="color:#8a8a9a;font-size:0.85rem;">还没有内容</div>';
    return;
  }
  var html = '';
  items.forEach(function(n) {
    var dateStr = n.created_at ? new Date(n.created_at).toLocaleDateString() : '';
    var typeLabel = { note: '笔记', project: '项目', hobby: '爱好' }[n.type] || n.type;
    var typeClass = { note: 't-note', project: 't-project', hobby: 't-hobby' }[n.type] || '';
    var link = n.type === 'note' ? '/notes/' + n.id : (n.type === 'project' ? '/projects/' + (n.slug || n.id) : '/hobbies/' + (n.slug || n.id));
    html += '<div class="item">'
      + '<span class="type ' + typeClass + '">' + typeLabel + '</span> '
      + '<a href="' + link + '" target="_blank">' + escapeHtml(n.title) + '</a>'
      + '<span class="date">' + dateStr + '</span>'
      + '</div>';
  });
  container.innerHTML = html;
}

function escapeHtml(str) {
  var div = document.createElement('div');
  div.appendChild(document.createTextNode(str || ''));
  return div.innerHTML;
}

loadDashboard();
</script>
</body>
</html>
