---
import { verifyToken, COOKIE_NAME } from '../../../../lib/auth.js';
const token = Astro.cookies.get(COOKIE_NAME)?.value;
const username = token ? verifyToken(token) : null;
if (!username) return Astro.redirect('/admin/login');
---

<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>编辑笔记</title>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; }
    body { font-family:-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Noto Sans SC", sans-serif; background:#f5f4f0; color:#1c1a18; }
    .layout { display:flex; min-height:100vh; }
    .side { width:200px; background:#1a1a24; color:#c8c8d0; display:flex; flex-direction:column; flex-shrink:0; position:sticky; top:0; height:100vh; }
    .side-logo { padding:1.2rem; font-size:0.85rem; font-weight:600; border-bottom:1px solid rgba(255,255,255,0.08); }
    .side-nav { flex:1; padding:0.5rem 0; }
    .side-nav a { display:block; padding:0.6rem 1.2rem; font-size:0.85rem; color:#9a9aa8; text-decoration:none; border-left:2px solid transparent; }
    .side-nav a:hover { background:rgba(255,255,255,0.04); color:#e8e8f0; }
    .side-nav a.active { background:rgba(255,255,255,0.06); color:#fff; border-left-color:#c17f59; }
    .side-foot { padding:1rem 1.2rem; border-top:1px solid rgba(255,255,255,0.08); font-size:0.78rem; }
    .side-foot a { color:#7a7a8a; text-decoration:none; }
    .side-foot a:hover { color:#c17f59; }
    .main { flex:1; padding:2rem; max-width:960px; }
    .hd { margin-bottom:1.5rem; }
    .hd h1 { font-size:1.4rem; font-weight:600; }
    .card { background:#fff; border:1px solid rgba(0,0,0,0.06); border-radius:8px; padding:1.5rem; max-width:700px; }
    .fg { margin-bottom:1.2rem; }
    .fg label { display:block; font-size:0.82rem; font-weight:500; margin-bottom:0.3rem; color:#6b625b; }
    .fg input, .fg textarea, .fg select { width:100%; padding:0.5rem 0.8rem; border:1px solid rgba(0,0,0,0.08); border-radius:4px; font-size:0.9rem; font-family:inherit; }
    .fg input:focus, .fg textarea:focus { outline:none; border-color:#c17f59; }
    .fg textarea { resize:vertical; min-height:400px; font-family:Consolas, "JetBrains Mono", monospace; font-size:0.85rem; line-height:1.7; }
    .actions { display:flex; gap:0.5rem; align-items:center; margin-top:1.5rem; }
    .btn { padding:0.5rem 1.2rem; border-radius:4px; font-size:0.85rem; cursor:pointer; border:none; text-decoration:none; display:inline-block; }
    .btn-pri { background:#c17f59; color:#fff; }
    .btn-pri:hover { opacity:0.9; }
    .btn-sec { background:#f5f4f0; color:#1c1a18; border:1px solid rgba(0,0,0,0.1); }
    .btn-sec:hover { background:#e8e4dd; }
    .status { font-size:0.85rem; color:#8a8a9a; margin-left:1rem; }
    .note-id { font-size:0.8rem; color:#8a8a9a; margin-bottom:1rem; }
  </style>
</head>
<body>
<div class="layout">
  <aside class="side">
    <div class="side-logo">管理后台</div>
    <nav class="side-nav">
      <a href="/admin">概览</a>
      <a href="/admin/notes" class="active">笔记</a>
    </nav>
    <div class="side-foot">
      <a href="/">查看网站</a>
    </div>
  </aside>
  <main class="main">
    <div class="hd"><h1 id="pageTitle">编辑笔记</h1></div>

    <div class="note-id" id="noteId"></div>

    <div class="card">
      <div class="fg">
        <label>标题</label>
        <input type="text" id="title" placeholder="笔记标题">
      </div>
      <div class="fg">
        <label>课程分类</label>
        <select id="course"><option value="">无分类</option></select>
      </div>
      <div class="fg">
        <label>内容 (Markdown)</label>
        <textarea id="content" placeholder="用 Markdown 写笔记..."></textarea>
      </div>
      <div class="fg">
        <label>标签（逗号分隔）</label>
        <input type="text" id="tags" placeholder="例: 操作系统, 进程管理">
      </div>
      <div class="actions">
        <button class="btn btn-pri" id="saveBtn">保存</button>
        <a href="/admin/notes" class="btn btn-sec">返回</a>
        <span class="status" id="status"></span>
      </div>
    </div>
  </main>
</div>

<script>
var noteId = window.location.pathname.split('/').pop();

// Load note data
Promise.all([
  fetch('/api/notes/' + noteId).then(function(r) { return r.json(); }),
  fetch('/api/notes?limit=1').then(function(r) { return r.json(); })
]).then(function(results) {
  var note = results[0];
  var data = results[1];

  document.getElementById('pageTitle').textContent = '编辑: ' + note.title;
  document.getElementById('noteId').textContent = 'ID: ' + noteId;
  document.getElementById('title').value = note.title || '';
  document.getElementById('content').value = note.content || '';

  // Populate courses
  var sel = document.getElementById('course');
  (data.courses || []).forEach(function(c) {
    sel.innerHTML += '<option value="' + c + '">' + c + '</option>';
  });
  if (note.course) sel.value = note.course;

  // Parse tags
  var tags = [];
  try { tags = Array.isArray(note.tags) ? note.tags : JSON.parse(note.tags || '[]'); } catch(e) {}
  document.getElementById('tags').value = tags.join(', ');
}).catch(function(err) {
  document.getElementById('status').textContent = '加载失败';
});

document.getElementById('saveBtn').addEventListener('click', async function() {
  var status = document.getElementById('status');
  var title = document.getElementById('title').value.trim();
  if (!title) { status.textContent = '标题不能为空'; return; }

  var tags = document.getElementById('tags').value.split(',').map(function(t) { return t.trim(); }).filter(Boolean);

  status.textContent = '保存中...';
  var res = await fetch('/api/notes/' + noteId, {
    method: 'PUT',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      title: title,
      content: document.getElementById('content').value,
      course: document.getElementById('course').value,
      tags: tags
    })
  });
  if (res.ok) {
    status.textContent = '保存成功！';
  } else {
    var err = await res.json();
    status.textContent = '保存失败: ' + (err.error || '');
  }
});
</script>
</body>
</html>
