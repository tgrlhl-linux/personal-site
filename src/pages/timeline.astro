---
import Base from '../layouts/Base.astro';
import { query } from '../db/mysql';
import ContributionGraph from '../components/ContributionGraph.astro';
import { milestones, categoryConfig } from '../data/timeline-milestones.js';

// ── 热力图数据：各类型内容按日分布 ──
const heatRows = await query(
  `SELECT DATE(created_at) AS d, COUNT(*) AS c
   FROM notes WHERE created_at IS NOT NULL
   GROUP BY DATE(created_at) ORDER BY d`
);
const heatData = {};
const heatLabels = {};
for (const r of heatRows) {
  heatData[r.d] = parseInt(r.c);
}
// 从 milestones 补充标记（只取有确切日期的）
for (const m of milestones) {
  if (m.date && !m.date.startsWith('~')) {
    heatData[m.date] = (heatData[m.date] || 0) + 0.5;
    if (!heatLabels[m.date]) heatLabels[m.date] = [];
    heatLabels[m.date].push(m.title);
  }
}
// 将标签数组转为字符串
for (const k of Object.keys(heatLabels)) {
  heatLabels[k] = heatLabels[k].join(' · ');
}

// ── DB 内容列表 ──
const dbNotes = await query(
  "SELECT id, title, excerpt, created_at FROM notes WHERE type='note' AND status='published' ORDER BY created_at DESC"
);
const dbProjects = await query(
  "SELECT id, title, slug, excerpt, created_at FROM notes WHERE type='project' AND status='published' ORDER BY created_at DESC"
);

const dbEvents = [
  ...dbProjects.map(p => ({
    date: new Date(p.created_at),
    title: p.title,
    desc: p.excerpt || '',
    url: `/projects/${p.slug}`,
    type: 'project',
  })),
  ...dbNotes.map(n => ({
    date: new Date(n.created_at),
    title: n.title,
    desc: n.excerpt || '',
    url: `/notes/${n.id}`,
    type: 'note',
  })),
].sort((a, b) => b.date.valueOf() - a.date.valueOf());

// ── 里程碑按年月分组 ──
const sortedMs = [...milestones].sort((a, b) => {
  const da = a.date.replace(/^~/, '');
  const db = b.date.replace(/^~/, '');
  return db.localeCompare(da);
});

const msByMonth = {};
for (const m of sortedMs) {
  const date = m.date.replace(/^~/, '');
  const monthKey = date.slice(0, 7); // "2026-07"
  if (!msByMonth[monthKey]) msByMonth[monthKey] = [];
  msByMonth[monthKey].push(m);
}

const monthNames = {
  '01':'一月','02':'二月','03':'三月','04':'四月',
  '05':'五月','06':'六月','07':'七月','08':'八月',
  '09':'九月','10':'十月','11':'十一月','12':'十二月',
};

// 统计
const totalDays = Object.keys(heatData).length;
const totalProjects = dbProjects.length;
const totalMilestones = milestones.length;
---

<Base title="成长时间线" description="走过的每一步">
  <div class="page-header" data-reveal="bottom">
    <h1>🌱 成长时间线</h1>
    <p>每一步都算数</p>
  </div>

  <!-- Stats -->
  <div class="tl-stats" data-reveal="bottom">
    <div class="tl-stat" style="--sc:#58a6ff">
      <div class="tl-stat-num">{totalDays}</div>
      <div class="tl-stat-label">活跃天数</div>
    </div>
    <div class="tl-stat" style="--sc:#3fb950">
      <div class="tl-stat-num">{totalMilestones}</div>
      <div class="tl-stat-label">里程碑</div>
    </div>
    <div class="tl-stat" style="--sc:#f0883e">
      <div class="tl-stat-num">{totalProjects}</div>
      <div class="tl-stat-label">项目</div>
    </div>
    <div class="tl-stat" style="--sc:#d29922">
      <div class="tl-stat-num">{dbNotes.length}</div>
      <div class="tl-stat-label">笔记</div>
    </div>
  </div>

  <!-- Contribution Graph -->
  <div class="tl-card" data-reveal="bottom">
    <div class="tl-card-title">📊 贡献热力图</div>
    <ContributionGraph data={heatData} labels={heatLabels} />
  </div>

  <!-- Category Legend -->
  <div class="tl-cats" data-reveal="bottom">
    {Object.entries(categoryConfig).map(([k, v]) => (
      <span class="tl-cat" style={`--cc:${v.color};--cg:${v.glow}`}>
        <span class="tl-cat-dot" style={`background:${v.color}`}></span>
        {v.label}
      </span>
    ))}
    <span class="tl-cat-hint">~ 标记为近似日期</span>
  </div>

  <!-- Milestones -->
  <div class="tl-section" data-reveal="bottom">
    <h2 class="tl-section-title">🏆 成长里程碑</h2>
  </div>

  {Object.entries(msByMonth).map(([monthKey, items]) => {
    const [y, m] = monthKey.split('-');
    const label = `${y}年 ${monthNames[m] || m + '月'}`;
    return (
      <div class="month-group" data-reveal="bottom">
        <div class="month-heading">{label}</div>
        <div class="month-line">
          {items.map(m => {
            const cfg = categoryConfig[m.category] || categoryConfig.life;
            const day = m.date.replace(/^~/, '').slice(8);
            const isApprox = m.date.startsWith('~');
            return (
              <div class="ms-event" style={`--cc:${cfg.color};--cg:${cfg.glow}`}>
                <div class="ms-dot" style={`background:${cfg.color}`}></div>
                <div class="ms-body">
                  <div class="ms-meta">
                    <span class="ms-day">{isApprox ? '~' + day + '日' : day + '日'}</span>
                    <span class="ms-cat" style={`color:${cfg.color}`}>{cfg.label}</span>
                  </div>
                  <h3 class="ms-title">{m.title}</h3>
                  <p class="ms-desc">{m.desc}</p>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    );
  })}

  <!-- DB Events (compact) -->
  <div class="tl-section" data-reveal="bottom">
    <h2 class="tl-section-title">📝 内容时间线</h2>
    <p class="tl-section-desc">所有笔记和项目的创建记录</p>
  </div>

  {dbEvents.length === 0 ? (
    <div class="tl-empty">还没有内容</div>
  ) : (
    <div class="tl-compact" data-reveal="bottom">
      {(() => {
        const years = [...new Set(dbEvents.map(e => e.date.getFullYear()))].sort((a,b) => b - a);
        return years.map(year => (
          <div class="cy-group">
            <div class="cy-heading">{year}</div>
            {dbEvents.filter(e => e.date.getFullYear() === year).map(e => (
              <a href={e.url} class={`ce-item type-${e.type}`}>
                <div class="ce-dot"></div>
                <div class="ce-body">
                  <time class="ce-date">
                    {e.date.toLocaleDateString('zh-CN', { month: 'long', day: 'numeric' })}
                  </time>
                  <span class="ce-title">{e.title}</span>
                  {e.desc && <span class="ce-desc">{e.desc}</span>}
                </div>
                <span class="ce-arrow">→</span>
              </a>
            ))}
          </div>
        ));
      })()}
    </div>
  )}
</Base>

<style>
  /* ── Stats ── */
  .tl-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .tl-stat {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem;
    text-align: center;
  }
  .tl-stat-num {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--sc);
    line-height: 1.1;
    letter-spacing: -0.03em;
  }
  .tl-stat-label {
    font-size: 0.72rem;
    color: var(--text-muted);
    margin-top: 0.15rem;
  }
  @media (max-width: 640px) {
    .tl-stats { grid-template-columns: repeat(2, 1fr); }
  }

  /* ── Cards ── */
  .tl-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem 1.2rem 0.8rem;
    margin-bottom: 0.75rem;
  }
  .tl-card-title {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-secondary);
    margin-bottom: 0.3rem;
  }

  /* ── Category Legend ── */
  .tl-cats {
    display: flex;
    gap: 0.6rem;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
    padding: 0 0.2rem;
  }
  .tl-cat {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.75rem;
    color: var(--text-secondary);
  }
  .tl-cat-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
  }
  .tl-cat-hint {
    font-size: 0.7rem;
    color: var(--text-muted);
    margin-left: auto;
  }

  /* ── Section headers ── */
  .tl-section { margin: 1.5rem 0 0.5rem; }
  .tl-section-title { font-size: 1.2rem; margin: 0; }
  .tl-section-desc { font-size: 0.8rem; color: var(--text-muted); margin: 0.1rem 0 0; }

  /* ── Milestones Timeline ── */
  .month-group { margin-bottom: 1.5rem; }
  .month-heading {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.75rem;
    padding-left: 0.5rem;
    border-left: 3px solid var(--c-os);
  }
  .month-line {
    border-left: 2px solid var(--border);
    padding-left: 1.2rem;
    margin-left: 0.5rem;
  }
  .ms-event {
    display: flex;
    gap: 0.8rem;
    margin-bottom: 1.2rem;
    padding: 0.6rem 0.8rem;
    border-radius: var(--radius-sm);
    transition: background 0.15s;
    position: relative;
  }
  .ms-event:hover { background: var(--bg-hover); }
  .ms-dot {
    position: absolute;
    left: -1.45rem;
    top: 0.85rem;
    width: 11px; height: 11px;
    border-radius: 50%;
    border: 2px solid var(--bg-card);
    box-shadow: 0 0 0 2px var(--cc);
  }
  .ms-body { flex: 1; min-width: 0; }
  .ms-meta {
    display: flex;
    gap: 0.4rem;
    align-items: center;
    margin-bottom: 0.15rem;
  }
  .ms-day {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }
  .ms-cat {
    font-size: 0.65rem;
    padding: 0.05em 0.45em;
    border-radius: 4px;
    background: color-mix(in srgb, currentColor 15%, transparent);
  }
  .ms-title {
    font-size: 0.95rem;
    font-weight: 600;
    margin: 0 0 0.15rem;
    line-height: 1.4;
  }
  .ms-desc {
    font-size: 0.8rem;
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.5;
  }

  /* ── Compact event list (DB auto-generated) ── */
  .tl-compact { max-width: 600px; margin: 0 auto; }
  .cy-group { margin-bottom: 1.5rem; }
  .cy-heading {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--c-os);
    margin-bottom: 0.75rem;
  }
  .ce-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.6rem;
    margin-bottom: 0.35rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: var(--text);
    transition: background 0.12s;
  }
  .ce-item:hover { background: var(--bg-hover); }
  .ce-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--c-db);
  }
  .type-project .ce-dot { background: var(--c-project); }
  .type-note .ce-dot { background: var(--c-db); }
  .ce-body {
    flex: 1;
    display: flex;
    gap: 0.5rem;
    align-items: baseline;
    min-width: 0;
  }
  .ce-date {
    font-size: 0.7rem;
    color: var(--text-muted);
    white-space: nowrap;
    font-family: var(--font-mono);
  }
  .ce-title {
    font-size: 0.85rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .ce-desc {
    font-size: 0.75rem;
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .ce-arrow {
    font-size: 0.8rem;
    color: var(--text-muted);
    opacity: 0.3;
    transition: opacity 0.15s, transform 0.15s;
    flex-shrink: 0;
  }
  .ce-item:hover .ce-arrow {
    opacity: 1;
    transform: translateX(3px);
  }

  .tl-empty {
    text-align: center;
    padding: 3rem 0;
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    .ce-body { flex-direction: column; gap: 0.1rem; }
    .ce-desc { display: none; }
  }
</style>
