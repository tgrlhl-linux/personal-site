---
import Base from '../layouts/Base.astro';
import { query } from '../db/mysql';
import ContributionGraph from '../components/ContributionGraph.astro';
import LearningJourneyChart from '../components/LearningJourneyChart.astro';

// ── 热力图数据：各类型内容按日分布 ──
const heatRows = await query(
  `SELECT DATE(created_at) AS d, COUNT(*) AS c
   FROM notes WHERE created_at IS NOT NULL
   GROUP BY DATE(created_at) ORDER BY d`
);
const heatData = {};
const heatLabels = {};
for (const r of heatRows) {
  heatData[r.d] = parseInt(r.c);
  heatLabels[r.d] = r.c + ' 条记录';
}

// ── DB 内容统计 ──
const dbNotes = await query(
  "SELECT id, title, excerpt, created_at FROM notes WHERE type='note' AND status='published' ORDER BY created_at DESC"
);
const dbProjects = await query(
  "SELECT id, title, slug, excerpt, created_at FROM notes WHERE type='project' AND status='published' ORDER BY created_at DESC"
);

const dbEvents = [
  ...dbProjects.map(p => ({
    date: new Date(p.created_at),
    title: p.title,
    url: `/projects/${p.slug}`,
    type: 'project',
  })),
  ...dbNotes.map(n => ({
    date: new Date(n.created_at),
    title: n.title,
    url: `/notes/${n.id}`,
    type: 'note',
  })),
].sort((a, b) => b.date.valueOf() - a.date.valueOf());

const totalDays = Object.keys(heatData).length;
const totalProjects = dbProjects.length;
const totalNotes = dbNotes.length;
const totalItems = totalProjects + totalNotes;

const now = new Date();
const timeStr = now.toLocaleString('zh-CN', { hour12: false });
---

<Base title="成长时间线" description="从初中到大学的学习足迹">
  <div class="page-header" data-reveal="bottom">
    <h1>🌱 成长时间线</h1>
    <p class="tl-subtitle">从初中到大学 · 每一步都算数</p>
  </div>

  <!-- Stats -->
  <div class="tl-stats" data-reveal="bottom">
    <div class="tl-stat" style="--sc:#58a6ff">
      <div class="tl-stat-num">{totalDays}</div>
      <div class="tl-stat-label">活跃天数</div>
    </div>
    <div class="tl-stat" style="--sc:#3fb950">
      <div class="tl-stat-num">{totalItems}</div>
      <div class="tl-stat-label">内容总数</div>
    </div>
    <div class="tl-stat" style="--sc:#f0883e">
      <div class="tl-stat-num">{totalProjects}</div>
      <div class="tl-stat-label">项目</div>
    </div>
    <div class="tl-stat" style="--sc:#d29922">
      <div class="tl-stat-num">{totalNotes}</div>
      <div class="tl-stat-label">笔记</div>
    </div>
  </div>

  <!-- 贡献热力图（实时数据） -->
  <div class="tl-card" data-reveal="bottom">
    <div class="tl-card-hd">
      <span class="tl-card-title">📊 贡献热力图</span>
      <span class="tl-live">
        <span class="tl-live-dot"></span>
        实时 · 数据来自数据库
      </span>
    </div>
    <ContributionGraph data={heatData} labels={heatLabels} />
  </div>

  <!-- 学习旅程折线图 -->
  <div class="tl-card" data-reveal="bottom" id="journey-card">
    <div class="tl-card-hd">
      <span class="tl-card-title">📈 学习成长轨迹</span>
    </div>
    <LearningJourneyChart />
  </div>

  <!-- 近期内容快照 -->
  <div class="tl-card" data-reveal="bottom" id="recent-card">
    <div class="tl-card-hd">
      <span class="tl-card-title">📝 近期内容</span>
      <span class="tl-count">{dbEvents.length} 条</span>
    </div>
    <div class="tl-events">
      {dbEvents.length === 0 ? (
        <div class="tl-empty">还没有内容</div>
      ) : (
        dbEvents.slice(0, 15).map(e => (
          <a href={e.url} class={`tl-event type-${e.type}`}>
            <span class="tl-event-dot"></span>
            <time class="tl-event-date">
              {e.date.toLocaleDateString('zh-CN', { month: '2-digit', day: '2-digit' })}
            </time>
            <span class="tl-event-title">{e.title}</span>
            <span class="tl-event-type">{e.type === 'project' ? '项目' : '笔记'}</span>
          </a>
        ))
      )}
    </div>
  </div>
</Base>

<script>
// ── 热力图实时守护：每分钟检查新数据 ──
(function() {
  const INTERVAL = 60000; // 60s
  let lastCount = { items: 0, days: 0 };

  // 读取当前统计
  const statEls = document.querySelectorAll('.tl-stat-num');
  if (statEls.length >= 4) {
    lastCount.items = parseInt(statEls[1].textContent) || 0;
    lastCount.days = parseInt(statEls[0].textContent) || 0;
  }

  // 定时检查
  setInterval(async () => {
    try {
      const res = await fetch('/api/notes?limit=1');
      if (!res.ok) return;
      const data = await res.json();

      // 检查数据是否变化（用总条目数做快速判断）
      // data 包含 courses 列表和 notes 列表（limit=1时只返回1条）
      // 更精确：额外请求内容总数
      const countRes = await fetch('/api/contents');
      if (countRes.ok) {
        const countData = await countRes.json();
        // 如果contents API返回了总条目数
        if (countData.total !== undefined && countData.total !== lastCount.items) {
          lastCount.items = countData.total;
          // 软刷新页面
          const badge = document.querySelector('.tl-live');
          if (badge) {
            badge.innerHTML = '<span class="tl-live-dot tl-live-updated"></span> 已更新';
            badge.classList.add('tl-live-flash');
            setTimeout(() => {
              location.reload();
            }, 1500);
          }
        }
      }
    } catch (e) {
      // 静默失败，不干扰用户
    }
  }, INTERVAL);
})();
</script>

<style>
  .tl-subtitle { font-size: 0.9rem; color: var(--text-secondary); margin-top: 0.15rem; }

  /* ── Stats ── */
  .tl-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    margin-bottom: 1.2rem;
  }
  .tl-stat {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem;
    text-align: center;
  }
  .tl-stat-num {
    font-size: 1.8rem; font-weight: 700;
    color: var(--sc); line-height: 1.1;
    letter-spacing: -0.03em;
  }
  .tl-stat-label {
    font-size: 0.72rem; color: var(--text-muted);
    margin-top: 0.15rem;
  }
  @media (max-width: 640px) {
    .tl-stats { grid-template-columns: repeat(2, 1fr); }
  }

  /* ── Cards ── */
  .tl-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem 1.2rem;
    margin-bottom: 0.75rem;
  }
  .tl-card-hd {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.3rem;
  }
  .tl-card-title {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-secondary);
  }

  /* ── Live 实时标记 ── */
  .tl-live {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.68rem;
    color: var(--text-muted);
  }
  .tl-live-dot {
    display: inline-block;
    width: 7px; height: 7px;
    border-radius: 50%;
    background: #3fb950;
    animation: tl-pulse 2s infinite;
  }
  .tl-live-updated { background: #d29922; animation: none; }
  .tl-live-flash {
    animation: tl-flash 0.6s ease-out;
  }
  @keyframes tl-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  @keyframes tl-flash {
    0% { background: rgba(210,153,34,0.3); }
    100% { background: transparent; }
  }
  .tl-count {
    font-size: 0.72rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }

  /* ── Events ── */
  .tl-events { display: flex; flex-direction: column; gap: 0.15rem; }
  .tl-event {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.4rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: var(--text);
    transition: background 0.1s;
  }
  .tl-event:hover { background: var(--bg-hover); }
  .tl-event-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
    background: var(--c-db);
  }
  .type-project .tl-event-dot { background: var(--c-project); }
  .tl-event-date {
    font-size: 0.7rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    white-space: nowrap;
    min-width: 2.8em;
  }
  .tl-event-title {
    flex: 1;
    font-size: 0.82rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .tl-event-type {
    font-size: 0.6rem;
    padding: 0.1em 0.4em;
    border-radius: 4px;
    background: var(--bg-hover);
    color: var(--text-muted);
    white-space: nowrap;
  }
  .tl-empty {
    text-align: center;
    padding: 2rem 0;
    color: var(--text-muted);
    font-size: 0.85rem;
  }
</style>
