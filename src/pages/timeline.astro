---
import Base from '../layouts/Base.astro';
import { query } from '../db/mysql';

const dbNotes = await query("SELECT id, title, excerpt, created_at FROM notes WHERE type='note' AND status='published' ORDER BY created_at DESC");
const dbProjects = await query("SELECT id, title, slug, excerpt, metadata, created_at FROM notes WHERE type='project' AND status='published' ORDER BY created_at DESC");

type Event = {
  date: Date;
  title: string;
  description: string;
  type: 'project' | 'note';
  url: string;
};

const events: Event[] = [
  ...dbProjects.map(p => {
    const meta = (() => { try { return JSON.parse(p.metadata || '{}'); } catch { return {}; } })();
    return {
      date: meta.date ? new Date(meta.date) : new Date(p.created_at),
      title: p.title,
      description: p.excerpt || p.title,
      type: 'project' as const,
      url: `/projects/${p.slug}`,
    };
  }),
  ...dbNotes.map(n => ({
    date: new Date(n.created_at),
    title: n.title,
    description: n.excerpt || n.title,
    type: 'note' as const,
    url: `/notes/${n.id}`,
  })),
].sort((a, b) => b.date.valueOf() - a.date.valueOf());

const years = [...new Set(events.map(e => e.date.getFullYear()))].sort((a, b) => b - a);
---

<Base title="时间线" description="成长历程">
  <div class="page-header" data-reveal="bottom">
    <h1>时间线</h1>
    <p>走过的每一步</p>
  </div>

  {events.length === 0 ? (
    <div class="empty-state">还没有内容</div>
  ) : (
    <div class="timeline">
      {years.map(year => (
        <div class="year-group" data-reveal="bottom">
          <h2 class="year-heading">{year}</h2>
          <div class="year-line">
            {events.filter(e => e.date.getFullYear() === year).map(e => (
              <a href={e.url} class={`timeline-event type-${e.type}`}>
                <div class="event-dot"></div>
                <div class="event-body">
                  <time class="meta">
                    {e.date.toLocaleDateString('zh-CN', { month: 'long', day: 'numeric' })}
                  </time>
                  <h3>{e.title}</h3>
                  <p>{e.description}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  )}
</Base>

<style>
  .timeline { max-width: 600px; margin: 0 auto; }
  .year-group { margin-bottom: 2.5rem; }
  .year-heading {
    font-size: 1.5rem;
    color: var(--c-os);
    margin-bottom: 1rem;
    position: relative;
  }
  .year-line {
    border-left: 2px solid var(--c-os-glow);
    padding-left: 1.5rem;
    margin-left: 0.5rem;
  }
  .timeline-event {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
    text-decoration: none;
    color: var(--text);
    position: relative;
    padding: 0.8rem 1rem;
    border-radius: var(--radius);
    transition: background 0.2s;
  }
  .timeline-event:hover { background: var(--bg-hover); }
  .event-dot {
    position: absolute;
    left: -1.6rem;
    top: 1.1rem;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--bg-card);
    border: 2px solid var(--c-os);
  }
  .type-project .event-dot { background: var(--c-os); border-color: var(--c-os); }
  .type-note .event-dot { background: var(--c-db); border-color: var(--c-db); }
  .event-body { flex: 1; }
  .event-body time { display: block; margin-bottom: 0.2rem; font-size: 0.82rem; color: var(--text-muted); }
  .event-body h3 { font-size: 1rem; margin: 0 0 0.3rem; font-weight: 600; }
  .event-body p { font-size: 0.85rem; color: var(--text-secondary); margin: 0; line-height: 1.5; }
  .empty-state { text-align: center; padding: 4rem 0; color: var(--text-muted); }
</style>
