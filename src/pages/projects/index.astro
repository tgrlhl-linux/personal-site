---
import Base from '../../layouts/Base.astro';
import { query } from '../../db/mysql';

const projects = await query(
  `SELECT id, title, slug, excerpt, course as category, tags, metadata, created_at
   FROM notes WHERE type='project' AND status='published'
   ORDER BY created_at DESC`
);

const categoryLabels = {
  course: '课程',
  personal: '个人',
  tool: '工具',
};
const categoryColors = {
  course: '#f0883e',
  personal: '#79c0ff',
  tool: '#3fb950',
};
function catColor(c) { return categoryColors[c] || '#f0883e'; }
function catLabel(c) { return categoryLabels[c] || c; }

const grouped = {};
for (const p of projects) {
  const cat = p.category || 'course';
  if (!grouped[cat]) grouped[cat] = [];
  grouped[cat].push(p);
}

const catOrder = ['course', 'personal', 'tool'];
const sortedGroups = Object.entries(grouped).sort((a, b) => catOrder.indexOf(a[0]) - catOrder.indexOf(b[0]));
const totalStatus = { completed: 0, 'in-progress': 0, archived: 0 };
projects.forEach(p => {
  try {
    const m = JSON.parse(p.metadata || '{}');
    if (m.projectStatus) totalStatus[m.projectStatus]++;
  } catch {}
});
---

<Base title="项目" description="课程项目与个人作品" wide={true}>
  <div class="pp-header" data-reveal="bottom">
    <div>
      <h1>项目</h1>
      <div class="pp-sub">{projects.length} 个项目 · {sortedGroups.length} 个分类</div>
    </div>
  </div>

  {projects.length === 0 ? (
    <div class="pp-empty">还没有项目</div>
  ) : (
    <div class="pp-layout">

      <!-- Stats row -->
      <div class="pp-stats" data-reveal="bottom">
        <div class="pp-stat" style="--sc:#f0883e;--sb:rgba(240,136,62,0.2)">
          <div class="stat-icon">🛠️</div>
          <div class="stat-num">{projects.length}</div>
          <div class="stat-label">项目总数</div>
        </div>
        <div class="pp-stat" style="--sc:#79c0ff;--sb:rgba(121,192,255,0.2)">
          <div class="stat-icon">📂</div>
          <div class="stat-num">{sortedGroups.length}</div>
          <div class="stat-label">分类</div>
        </div>
        <div class="pp-stat" style="--sc:#3fb950;--sb:rgba(63,185,80,0.2)">
          <div class="stat-icon">✅</div>
          <div class="stat-num">{totalStatus.completed || 0}</div>
          <div class="stat-label">已完成</div>
        </div>
        <div class="pp-stat" style="--sc:#d29922;--sb:rgba(210,153,34,0.2)">
          <div class="stat-icon">🔄</div>
          <div class="stat-num">{totalStatus['in-progress'] || 0}</div>
          <div class="stat-label">进行中</div>
        </div>
      </div>

      <!-- Category groups with two-column cards -->
      <div class="pp-cards" data-reveal="bottom" data-delay="100">
        {sortedGroups.map(([cat, items]) => (
          <div class="pp-group" style={`--cc:${catColor(cat)}`}>
            <div class="pg-hd">
              <span class="pg-dot" style={`background:${catColor(cat)}`}></span>
              <span class="pg-name">{catLabel(cat)}</span>
              <span class="pg-count">{items.length}</span>
            </div>
            <div class="pg-body">
              {items.map((p, i) => {
                const meta = (() => { try { return JSON.parse(p.metadata || '{}'); } catch { return {}; } })();
                const dateStr = meta.date ? new Date(meta.date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'short' }) : '';
                const tagList = (() => { try { return JSON.parse(p.tags || '[]'); } catch { return []; } })();
                const statusLabel = meta.projectStatus === 'completed' ? '已完成' : meta.projectStatus === 'in-progress' ? '进行中' : '';
                return (
                  <a href={`/projects/${p.slug}`} class="pg-card" style={`--cc:${catColor(cat)}`}>
                    <!-- Left: compact -->
                    <div class="pgc-left" transition:name={`proj-card-${p.slug}`}>
                      <div class="pgc-num">{String(i + 1).padStart(2, '0')}</div>
                      <div class="pgc-badge" style={`background:${catColor(cat)}`}>{catLabel(cat)}</div>
                      <div class="pgc-title">{p.title}</div>
                      <div class="pgc-tags">
                        {tagList.slice(0, 3).map(t => <span class="pgc-tag">{t}</span>)}
                      </div>
                    </div>
                    <!-- Right: detailed -->
                    <div class="pgc-right">
                      <div class="pgc-desc">{p.excerpt}</div>
                      <div class="pgc-meta">
                        {statusLabel ? <span class={`pgc-status status-${meta.projectStatus}`}>{statusLabel}</span> : ''}
                        {dateStr ? <span class="pgc-date">{dateStr}</span> : ''}
                      </div>
                    </div>
                    <div class="pgc-arrow">→</div>
                  </a>
                );
              })}
            </div>
          </div>
        ))}
      </div>

    </div>
  )}
</Base>

<style>
  .pp-header { margin-bottom: 1.2rem; }
  .pp-header h1 { margin: 0; }
  .pp-sub { font-size: 0.82rem; color: var(--text-muted); margin-top: 0.1rem; }
  .pp-empty { text-align: center; padding: 4rem; color: var(--text-muted); }

  .pp-layout { max-width: var(--max-width-wide); margin: 0 auto; }

  /* ── Stats row ── */
  .pp-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .pp-stat {
    background: var(--bg-card);
    border: 1px solid var(--sb);
    border-radius: var(--radius);
    padding: 0.8rem 0.6rem;
    text-align: center;
  }
  .pp-stat .stat-icon { font-size: 1rem; margin-bottom: 0.15rem; }
  .pp-stat .stat-num { font-size: 1.5rem; font-weight: 700; color: var(--sc); line-height: 1.1; }
  .pp-stat .stat-label { font-size: 0.7rem; color: var(--text-muted); margin-top: 0.05rem; }

  /* ── Category groups ── */
  .pp-cards { display: flex; flex-direction: column; gap: 1.5rem; }
  .pp-group {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .pg-hd {
    padding: 0.7rem 1.2rem 0.3rem;
    display: flex; align-items: center; gap: 0.4rem;
  }
  .pg-dot { width: 8px; height: 8px; border-radius: 50%; box-shadow: 0 0 6px var(--cc); }
  .pg-name { font-weight: 600; font-size: 0.9rem; }
  .pg-count { font-size: 0.65rem; color: var(--text-muted); background: var(--bg-hover); padding: 0.05em 0.45em; border-radius: 6px; }

  /* ── Two-column cards ── */
  .pg-body { padding: 0.3rem 0.8rem 0.8rem; display: flex; flex-direction: column; gap: 0.5rem; }
  .pg-card {
    display: grid;
    grid-template-columns: 200px 1fr 2rem;
    gap: 0;
    align-items: center;
    padding: 0;
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: var(--text);
    background: var(--bg);
    border: 1px solid var(--border);
    overflow: hidden;
    transition: box-shadow 0.2s, transform 0.15s, border-color 0.2s;
    position: relative;
  }
  .pg-card:hover {
    box-shadow: 0 0 0 1px var(--cc), var(--shadow-hover);
    transform: translateY(-2px);
    border-color: var(--cc);
  }

  /* Left panel — compact */
  .pgc-left {
    background: linear-gradient(135deg, rgba(from var(--cc) r g b / 0.06), transparent);
    padding: 0.9rem 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    min-height: 100px;
    border-right: 1px solid var(--border);
  }
  .pgc-num {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-muted);
    letter-spacing: 0.03em;
  }
  .pgc-badge {
    display: inline-block;
    font-size: 0.6rem;
    padding: 0.15em 0.6em;
    border-radius: 4px;
    color: #fff;
    width: fit-content;
    font-weight: 500;
  }
  .pgc-title {
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.3;
    margin-top: 0.15rem;
  }
  .pgc-tags {
    display: flex;
    gap: 0.2rem;
    flex-wrap: wrap;
    margin-top: 0.1rem;
  }
  .pgc-tag {
    font-size: 0.6rem;
    padding: 0.1em 0.4em;
    background: var(--bg-hover);
    border-radius: 3px;
    color: var(--text-secondary);
    white-space: nowrap;
  }

  /* Right panel — detailed */
  .pgc-right {
    padding: 0.9rem 0.8rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    min-height: 100px;
    justify-content: center;
  }
  .pgc-desc {
    font-size: 0.8rem;
    color: var(--text-secondary);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .pgc-meta {
    display: flex;
    gap: 0.6rem;
    align-items: center;
    margin-top: 0.15rem;
  }
  .pgc-status {
    font-size: 0.65rem;
    padding: 0.1em 0.5em;
    border-radius: 4px;
  }
  .status-completed { background: rgba(63,185,80,0.15); color: #3fb950; }
  .status-in-progress { background: rgba(210,153,34,0.15); color: #d29922; }
  .pgc-date { font-size: 0.65rem; color: var(--text-muted); }

  /* Arrow indicator */
  .pgc-arrow {
    font-size: 1rem;
    color: var(--text-muted);
    padding-right: 0.6rem;
    opacity: 0.3;
    transition: opacity 0.2s, transform 0.2s;
  }
  .pg-card:hover .pgc-arrow {
    opacity: 1;
    transform: translateX(3px);
    color: var(--cc);
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .pp-stats { grid-template-columns: repeat(2, 1fr); }
    .pg-card { grid-template-columns: 160px 1fr 1.5rem; }
  }
  @media (max-width: 600px) {
    .pp-stats { grid-template-columns: repeat(2, 1fr); }
    .pg-card { grid-template-columns: 1fr; }
    .pgc-left {
      border-right: none;
      border-bottom: 1px solid var(--border);
      min-height: auto;
      padding: 0.6rem 0.7rem;
    }
    .pgc-right { padding: 0.5rem 0.7rem; min-height: auto; }
    .pgc-arrow { display: none; }
  }
</style>
