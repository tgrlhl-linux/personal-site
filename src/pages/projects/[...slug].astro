---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import { query } from '../../db/mysql';
import projectCode from '../../data/projectCode';

const slug = Astro.params.slug;

let error = null;
let project = null;

if (!slug) {
  error = '无效的项目';
} else if (slug === 'code') {
  return Astro.redirect('/projects', 302);
} else {
  const rows = await query("SELECT * FROM notes WHERE type='project' AND slug = ?", [slug]);
  if (rows.length === 0) error = '项目不存在';
  else project = rows[0];
}

function safeParse(val, fallback) {
  if (val == null) return fallback;
  if (typeof val === 'object') return val;
  try { return JSON.parse(val); } catch { return fallback; }
}
const meta = project ? safeParse(project.metadata, {}) : {};
const tagList = project ? safeParse(project.tags, []) : [];
const statusLabel = { completed: '已完成', 'in-progress': '进行中', archived: '归档' };
const catLabel = { course: '课程', personal: '个人', tool: '工具' };

const codeData = project ? projectCode[project.slug] : null;
const hasCode = codeData?.snippets?.length > 0;
const hasFiles = codeData?.fullFiles?.length > 0;
const hasDemo = codeData?.hasDemo;

function esc(str) {
  if (!str) return '';
  return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
}
function codeLines(code) {
  return (code || '').split('\n').length;
}
---

{error ? (
  <Base title="项目不存在">
    <div class="page-header">
      <h1>项目不存在</h1>
      <p><a href="/projects">← 返回项目列表</a></p>
    </div>
  </Base>
) : (
  <Base title={project.title}>
    <article class="post">
      <header class="post-header">
        <div class="post-meta">
          <span class="tag">{catLabel[project.course] || project.course}</span>
          {meta.projectStatus && meta.projectStatus !== 'completed' && <span class="tag status-tag">{statusLabel[meta.projectStatus]}</span>}
          {meta.date && <time class="meta">{new Date(meta.date).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}</time>}
        </div>
        <h1>{project.title}</h1>
        {codeData?.highlights && <p class="post-highlight">{codeData.highlights}</p>}
        <div class="post-tags">
          {tagList.map(t => <span class="tag">{t}</span>)}
          {codeData?.tech?.map(t => <span class="tag tech-tag">{t}</span>)}
        </div>
      </header>

      <!-- ═══ 项目说明 ═══ -->
      <section>
        <div class="section-heading">📖 项目说明</div>
        <div class="post-content" id="content">{project.content || ''}</div>
      </section>

      <!-- ═══ 代码展示 ═══ -->
      {hasCode && (
        <section>
          <div class="section-heading">💻 核心代码</div>
          {codeData.tech && <p class="section-sub">{codeData.tech.join(' · ')}</p>}
          <div class="code-gallery">
            {codeData.snippets.map((s, i) => (
              <div class="code-card">
                <div class="code-card-hd">
                  <div class="code-card-title">
                    <span class="code-lang-badge">{s.language}</span>
                    <strong>{s.title}</strong>
                  </div>
                  <div class="code-card-meta">{s.file} · {codeLines(s.code)} 行</div>
                </div>
                {s.description && <p class="code-card-desc">{s.description}</p>}
                <div class="code-wrapper">
                  <button class="code-copy" data-code-idx={i} title="复制代码">📋</button>
                  <pre class="code-block"><code class="lang-{s.language}">{esc(s.code)}</code></pre>
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- ═══ 文件结构 ═══ -->
      {hasFiles && (
        <section>
          <div class="section-heading">📁 源文件清单</div>
          <p class="section-sub">完整代码见 <a href={codeData.githubUrl} target="_blank">GitHub 仓库 ↗</a></p>
          <table class="file-table">
            <thead>
              <tr><th>路径</th><th>说明</th><th>行数</th></tr>
            </thead>
            <tbody>
              {codeData.fullFiles.map(f => (
                <tr>
                  <td class="file-path"><code>{f.path}</code></td>
                  <td>{f.desc}</td>
                  <td class="file-lines">{f.lines}</td>
                </tr>
              ))}
            </tbody>
          </table>
          {codeData.features?.length > 0 && (
            <div class="feat-section">
              <div class="section-heading" style="margin-top:1.5rem">✨ 功能特性</div>
              <ul class="feat-list">
                {codeData.features.map(f => <li>{f}</li>)}
              </ul>
            </div>
          )}
        </section>
      )}

      <!-- ═══ 在线体验 ═══ -->
      {hasDemo && (
        <section>
          <div class="section-heading">🚀 在线体验</div>
          {codeData.demoType === 'inline' ? (
            <div class="demo-inline">
              {codeData.note && <p class="demo-note">{codeData.note}</p>}
              <div class="demo-frame-wrap">
                <iframe src={codeData.demoUrl} class="demo-frame" title="在线演示"></iframe>
              </div>
              <div class="demo-open-bar">
                <a href={codeData.demoUrl} target="_blank" class="btn btn-outline">在新窗口打开 ↗</a>
              </div>
            </div>
          ) : codeData.demoType === 'external' ? (
            <div class="demo-external">
              <div class="demo-card">
                <div class="demo-card-icon">🔗</div>
                <div class="demo-card-body">
                  <p>该项目的在线版本已部署到独立平台。</p>
                  <a href={codeData.demoUrl} target="_blank" class="btn">{codeData.demoUrl} ↗</a>
                </div>
              </div>
            </div>
          ) : (
            <div class="demo-na">
              <p>该项目为 CLI/GUI 应用，无法在网页端直接运行。</p>
              <p>如需查看运行效果，请前往 <a href={codeData.githubUrl} target="_blank">GitHub 仓库 ↗</a> 查看截图和说明。</p>
            </div>
          )}
        </section>
      )}

      <nav class="post-nav">
        <a href="/projects" class="btn">← 返回项目列表</a>
      </nav>
    </article>

    <script>
      // ── Markdown rendering ──
      import { marked } from 'marked';
      marked.setOptions({ breaks: true, gfm: true });
      const contentEl = document.getElementById('content');
      if (contentEl) contentEl.innerHTML = marked.parse(contentEl.textContent);

      // ── Copy code ──
      document.querySelectorAll('.code-copy').forEach(btn => {
        btn.addEventListener('click', () => {
          const pre = btn.parentElement.querySelector('code');
          if (!pre) return;
          const text = pre.textContent || pre.innerText;
          navigator.clipboard.writeText(text).then(() => {
            btn.textContent = '✅';
            setTimeout(() => { btn.textContent = '📋'; }, 1500);
          }).catch(() => {});
        });
      });
    </script>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css">
    <script is:inline>
    (function() {
      var s = document.createElement('script');
      s.src = 'https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js';
      s.onload = function() {
        // Load languages
        var langs = ['java','python','rust','bash','sql','javascript','xml'];
        var loaded = 0;
        langs.forEach(function(lang) {
          var ls = document.createElement('script');
          ls.src = 'https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/languages/' + lang + '.min.js';
          ls.onload = ls.onerror = function() { loaded++; if (loaded >= langs.length) highlight(); };
          document.head.appendChild(ls);
        });
        setTimeout(highlight, 3000);
        function highlight() {
          document.querySelectorAll('.code-block code').forEach(function(el) {
            if (typeof hljs !== 'undefined') hljs.highlightElement(el);
          });
        }
      };
      document.head.appendChild(s);
    })();
    </script>
  </Base>
)}

<style>
  /* ── Header ── */
  .post-header { margin-bottom: 1.5rem; padding-bottom: 1.2rem; border-bottom: 1px solid var(--border); }
  .post-meta { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.6rem; flex-wrap: wrap; }
  .post-meta .meta { margin: 0; color: var(--text-muted); }
  .post-header h1 { font-size: 1.6rem; margin-bottom: 0.4rem; }
  .post-highlight { font-size: 0.9rem; color: var(--text-secondary); line-height: 1.6; margin-bottom: 0.6rem; }
  .post-tags { display: flex; flex-wrap: wrap; gap: 0.3rem; }
  .status-tag { background: rgba(210,153,34,0.15); color: #d29922; }
  .tech-tag { background: rgba(88,166,255,0.12); color: #58a6ff; border-color: rgba(88,166,255,0.2); }

  /* ── Section headings ── */
  section { margin-top: 2rem; }
  .section-heading {
    font-size: 1.05rem; font-weight: 600; color: var(--text);
    padding-bottom: 0.4rem; margin-bottom: 0.8rem;
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center; gap: 0.4rem;
  }
  .section-sub { font-size: 0.82rem; color: var(--text-muted); margin: -0.3rem 0 0.8rem; }

  /* ── Markdown content ── */
  .post-content { font-size: 0.95rem; line-height: 1.8; }
  .post-content :global(h2) { font-size: 1.2rem; margin-top: 1.5rem; }
  .post-content :global(h3) { font-size: 1.05rem; margin-top: 1.2rem; }
  .post-content :global(p) { margin-bottom: 0.8rem; }
  .post-content :global(ul) { margin-left: 1.5rem; margin-bottom: 0.8rem; }
  .post-content :global(li) { margin-bottom: 0.3rem; }
  .post-content :global(code) { font-family: var(--font-mono); font-size: 0.85em; background: var(--bg-hover); padding: 0.15em 0.4em; border-radius: 3px; }
  .post-content :global(pre) { background: #151b22; padding: 1rem; border-radius: 8px; overflow-x: auto; margin: 1rem 0; border: 1px solid var(--border); }
  .post-content :global(pre code) { background: none; padding: 0; }
  .post-content :global(blockquote) { border-left: 3px solid var(--c-os); padding: 0.5rem 1rem; margin: 1rem 0; color: var(--text-secondary); background: var(--bg-hover); border-radius: 0 var(--radius-sm) var(--radius-sm) 0; }
  .post-content :global(table) { width: 100%; border-collapse: collapse; margin: 1rem 0; font-size: 0.88rem; }
  .post-content :global(th), .post-content :global(td) { border: 1px solid var(--border); padding: 0.4rem 0.6rem; text-align: left; }
  .post-content :global(th) { background: var(--bg-hover); font-weight: 600; }
  .post-content :global(img) { max-width: 100%; height: auto; border-radius: 8px; margin: 1rem 0; }

  /* ── Code cards ── */
  .code-gallery { display: flex; flex-direction: column; gap: 1rem; }
  .code-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px; overflow: hidden;
  }
  .code-card-hd {
    display: flex; justify-content: space-between; align-items: center;
    padding: 0.5rem 1rem; border-bottom: 1px solid var(--border);
    flex-wrap: wrap; gap: 0.3rem;
  }
  .code-card-title { display: flex; align-items: center; gap: 0.5rem; font-size: 0.88rem; }
  .code-card-title strong { color: var(--text); }
  .code-lang-badge {
    font-size: 0.62rem; padding: 0.1em 0.5em;
    background: rgba(88,166,255,0.15); color: #58a6ff;
    border-radius: 4px; font-family: var(--font-mono); text-transform: uppercase;
  }
  .code-card-meta { font-size: 0.72rem; color: var(--text-muted); font-family: var(--font-mono); }
  .code-card-desc { padding: 0.5rem 1rem 0; font-size: 0.82rem; color: var(--text-secondary); line-height: 1.6; }
  .code-wrapper { position: relative; }
  .code-copy {
    position: absolute; top: 0.4rem; right: 0.5rem;
    background: rgba(255,255,255,0.06); border: 1px solid var(--border);
    color: var(--text-muted); cursor: pointer;
    padding: 0.2rem 0.4rem; border-radius: 4px;
    font-size: 0.82rem; z-index: 2;
    transition: all 0.15s;
  }
  .code-copy:hover { background: var(--bg-hover); color: var(--text); }
  .code-block { margin: 0 !important; border: none !important; border-radius: 0 !important; background: #0d1117 !important; }
  .code-block code { font-size: 0.78rem !important; line-height: 1.55 !important; }

  /* ── File table ── */
  .file-table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
  .file-table th, .file-table td { padding: 0.35rem 0.6rem; text-align: left; border-bottom: 1px solid var(--border); }
  .file-table th { color: var(--text-muted); font-weight: 500; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em; }
  .file-table tr:hover td { background: var(--bg-hover); }
  .file-path code { font-size: 0.78rem; color: #58a6ff; }
  .file-lines { text-align: center; color: var(--text-muted); font-family: var(--font-mono); width: 3rem; }
  .feat-list { list-style: none; padding: 0; }
  .feat-list li {
    padding: 0.3rem 0 0.3rem 1.2rem;
    position: relative; font-size: 0.85rem;
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border);
  }
  .feat-list li:last-child { border-bottom: none; }
  .feat-list li::before { content: '▸'; position: absolute; left: 0; color: var(--accent); font-weight: bold; }

  /* ── Demo ── */
  .demo-frame-wrap { border: 1px solid var(--border); border-radius: 10px; overflow: hidden; background: var(--bg-card); }
  .demo-frame { width: 100%; height: 65vh; border: none; display: block; }
  .demo-open-bar { display: flex; justify-content: center; padding: 0.6rem; }
  .demo-note { font-size: 0.82rem; color: var(--text-secondary); margin-bottom: 0.8rem; padding: 0.5rem 0.8rem; background: rgba(255,255,255,0.03); border-radius: 6px; border-left: 2px solid var(--accent); }
  .demo-external { padding: 0.5rem 0; }
  .demo-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px; padding: 1.5rem; display: flex; gap: 1rem; align-items: center; }
  .demo-card-icon { font-size: 2rem; }
  .demo-card-body p { font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 0.5rem; }
  .demo-na { background: var(--bg-card); border: 1px solid var(--border); border-radius: 10px; padding: 1.5rem; text-align: center; }
  .demo-na p { font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 0.3rem; }
  .post-nav { margin-top: 2.5rem; }

  @media (max-width: 640px) {
    .post-header h1 { font-size: 1.3rem; }
    .code-card-hd { flex-direction: column; align-items: flex-start; }
    .demo-frame { height: 45vh; }
  }
</style>
