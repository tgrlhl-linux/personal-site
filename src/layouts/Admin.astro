---
const adminToken = Astro.cookies.get('admin_token')?.value;
const adminUser = Astro.env.ADMIN_USERNAME || 'admin';
let authenticated = false;

if (adminToken) {
  try {
    const decoded = Buffer.from(adminToken, 'base64').toString();
    const [username] = decoded.split(':');
    authenticated = username === adminUser;
  } catch {}
}
---

<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title ? `${title} — 管理后台` : '管理后台'}</title>
  <link rel="stylesheet" href="/admin/admin.css">
</head>
<body>
  <div class="admin-wrap">
    {authenticated && (
      <aside class="admin-sidebar">
        <div class="admin-logo">📝 管理后台</div>
        <nav class="admin-nav">
          <a href="/admin" class={Astro.url.pathname === '/admin' ? 'active' : ''}>📊 概览</a>
          <a href="/admin/notes" class={Astro.url.pathname.startsWith('/admin/notes') ? 'active' : ''}>📄 笔记</a>
          <a href="/admin/hobbies" class={Astro.url.pathname.startsWith('/admin/hobbies') ? 'active' : ''}>✏️ 爱好</a>
        </nav>
        <div class="admin-sidebar-footer">
          <a href="/" target="_blank">← 查看网站</a>
          <button onclick="logout()" class="btn-logout">退出</button>
        </div>
      </aside>
    )}
    <main class="admin-main">
      <slot />
    </main>
  </div>

  {authenticated && (
    <script>
      async function logout() {
        await fetch('/api/admin/logout', { method: 'POST' });
        window.location.href = '/admin/login';
      }
    </script>
  )}
</body>
</html>

<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  :root {
    --bg: #f5f4f0;
    --bg-card: #fff;
    --sidebar: #1a1a24;
    --text: #1c1a18;
    --text-muted: #8a8a9a;
    --accent: #c17f59;
    --border: rgba(0,0,0,0.06);
    --radius: 8px;
  }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Noto Sans SC", sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.5;
  }
  .admin-wrap { display: flex; min-height: 100vh; }
  .admin-sidebar {
    width: 200px; background: var(--sidebar); color: #c8c8d0;
    display: flex; flex-direction: column; padding: 1.5rem 0;
    flex-shrink: 0; position: sticky; top: 0; height: 100vh;
  }
  .admin-logo {
    padding: 0 1.2rem 1rem; font-size: 0.85rem; font-weight: 600;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    margin-bottom: 1rem;
  }
  .admin-nav { flex: 1; display: flex; flex-direction: column; gap: 0; }
  .admin-nav a {
    padding: 0.6rem 1.2rem; font-size: 0.85rem;
    color: #9a9aa8; text-decoration: none;
    transition: all 0.15s; border-left: 2px solid transparent;
  }
  .admin-nav a:hover { background: rgba(255,255,255,0.04); color: #e8e8f0; }
  .admin-nav a.active { background: rgba(255,255,255,0.06); color: #fff; border-left-color: var(--accent); }
  .admin-sidebar-footer {
    padding: 1rem 1.2rem; border-top: 1px solid rgba(255,255,255,0.08);
    display: flex; flex-direction: column; gap: 0.5rem;
  }
  .admin-sidebar-footer a { font-size: 0.78rem; color: #7a7a8a; text-decoration: none; }
  .admin-sidebar-footer a:hover { color: var(--accent); }
  .btn-logout {
    background: none; border: 1px solid rgba(255,255,255,0.1);
    color: #7a7a8a; padding: 0.3rem 0.6rem; border-radius: 4px;
    font-size: 0.75rem; cursor: pointer;
  }
  .btn-logout:hover { border-color: #ff6b6b; color: #ff6b6b; }
  .admin-main { flex: 1; padding: 2rem; max-width: 900px; }
</style>
